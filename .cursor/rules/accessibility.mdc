## Screen Reader Support

### ARIA Patterns

```typescript
// app/components/ui/dialog.tsx
export function Dialog({
  isOpen,
  onClose,
  title,
  children,
}: DialogProps) {
  const dialogRef = useRef<HTMLDivElement>(null);
  useFocusTrap(dialogRef);

  return (
    <div
      role="dialog"
      aria-modal="true"
      aria-labelledby="dialog-title"
      ref={dialogRef}
      hidden={!isOpen}
      className={cn('dialog', isOpen && 'dialog--open')}
    >
      <header>
        <h2 id="dialog-title">{title}</h2>
        <button
          onClick={onClose}
          aria-label="Close dialog"
          className="dialog__close"
        >
          <span aria-hidden="true">&times;</span>
        </button>
      </header>
      <div className="dialog__content">{children}</div>
    </div>
  );
}
```

### Live Regions

```typescript
// app/components/ui/alert.tsx
export function Alert({
  message,
  type = 'info',
}: {
  message: string;
  type?: 'info' | 'success' | 'error';
}) {
  return (
    <div
      role="alert"
      aria-live={type === 'error' ? 'assertive' : 'polite'}
      className={cn('alert', `alert--${type}`)}
    >
      {message}
    </div>
  );
}

// Toast notifications
export function Toast({ message }: { message: string }) {
  return (
    <div
      role="status"
      aria-live="polite"
      className="toast"
    >
      {message}
    </div>
  );
}
```

## Color and Contrast

### Color Utilities

```typescript
// app/lib/utils/color.ts
export const colorContrastRatios = {
  normal: 4.5, // WCAG AA for normal text
  large: 3, // WCAG AA for large text
  enhanced: 7, // WCAG AAA for normal text
  enhancedLarge: 4.5, // WCAG AAA for large text
};

export function getContrastRatio(
  foreground: string,
  background: string,
): number {
  const fg = getLuminance(foreground);
  const bg = getLuminance(background);

  return (Math.max(fg, bg) + 0.05) / (Math.min(fg, bg) + 0.05);
}

export function isAccessible(
  foreground: string,
  background: string,
  size: 'normal' | 'large' = 'normal',
): boolean {
  const ratio = getContrastRatio(foreground, background);
  return (
    ratio >=
    (size === 'large' ? colorContrastRatios.large : colorContrastRatios.normal)
  );
}
```

### Theme Configuration

```typescript
// app/lib/theme/colors.ts
export const colors = {
  primary: {
    50: '#f0f9ff',
    100: '#e0f2fe',
    // ... ensure all combinations meet contrast requirements
  },
  error: {
    light: '#fef2f2',
    main: '#dc2626',
    dark: '#991b1b',
  },
  success: {
    light: '#f0fdf4',
    main: '#16a34a',
    dark: '#166534',
  },
} as const;

// Validate color combinations
Object.entries(colors).forEach(([name, variants]) => {
  Object.entries(variants).forEach(([shade, color]) => {
    if (!isAccessible(color, colors.background)) {
      console.warn(
        `Color ${name}.${shade} does not meet contrast requirements`,
      );
    }
  });
});
```

## Forms and Validation

### Accessible Form Controls

```typescript
// app/components/ui/form.tsx
export function FormField({
  id,
  label,
  error,
  required,
  children,
}: FormFieldProps) {
  const fieldId = useId();
  const errorId = `${fieldId}-error`;

  return (
    <div className="form-field">
      <label
        htmlFor={fieldId}
        className={cn('form-label', required && 'form-label--required')}
      >
        {label}
        {required && (
          <span className="sr-only">(Required)</span>
        )}
      </label>

      {React.cloneElement(children, {
        id: fieldId,
        'aria-required': required,
        'aria-invalid': !!error,
        'aria-describedby': error ? errorId : undefined,
      })}

      {error && (
        <div
          id={errorId}
          className="form-error"
          role="alert"
        >
          {error}
        </div>
      )}
    </div>
  );
}
```

### Error Messaging

```typescript
// app/components/ui/form-error.tsx
export function FormError({ errors }: { errors: FieldError[] }) {
  if (errors.length === 0) return null;

  return (
    <div
      role="alert"
      aria-live="polite"
      className="form-errors"
    >
      <h2 className="sr-only">Form Errors</h2>
      <ul>
        {errors.map((error, index) => (
          <li key={index}>
            <a href={`#${error.field}`}>
              {error.message}
            </a>
          </li>
        ))}
      </ul>
    </div>
  );
}
```

## Testing

### Accessibility Testing

```typescript
// tests/accessibility/a11y.test.ts
import { axe, toHaveNoViolations } from 'jest-axe';

expect.extend(toHaveNoViolations);

describe('Accessibility', () => {
  it('should have no accessibility violations', async () => {
    const { container } = render(<MyComponent />);
    const results = await axe(container);
    expect(results).toHaveNoViolations();
  });

  it('should be keyboard navigable', async () => {
    render(<MyComponent />);

    const button = screen.getByRole('button');
    expect(button).toHaveFocus();

    userEvent.tab();
    expect(screen.getByRole('link')).toHaveFocus();
  });
});
```

## Responsive Design

### Responsive Patterns

```typescript
// app/components/ui/responsive-table.tsx
export function ResponsiveTable({ data }: { data: TableData[] }) {
  return (
    <div className="responsive-table" role="region" aria-label="Data table">
      <table>
        <caption>Data Table</caption>
        <thead>
          <tr>
            {columns.map((column) => (
              <th key={column.key} scope="col">
                {column.label}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {data.map((row) => (
            <tr key={row.id}>
              {columns.map((column) => (
                <td key={column.key} data-label={column.label}>
                  {row[column.key]}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  );
}
```

