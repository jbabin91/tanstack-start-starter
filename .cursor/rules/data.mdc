## Schema Patterns

### Base Schema

```typescript
// Base schema for shared fields
const baseEntitySchema = {
  id: text().primaryKey(),
  createdAt: timestamp('created_at', { withTimezone: true })
    .notNull()
    .$defaultFn(() => sql`CURRENT_TIMESTAMP AT TIME ZONE 'UTC'`),
  updatedAt: timestamp('updated_at', { withTimezone: true })
    .notNull()
    .$defaultFn(() => sql`CURRENT_TIMESTAMP AT TIME ZONE 'UTC'`)
    .$onUpdate(() => sql`CURRENT_TIMESTAMP AT TIME ZONE 'UTC'`),
};
```

### Table Definitions

```typescript
// Basic table with base schema
export const users = pgTable('users', {
  ...baseEntitySchema,
  email: text().notNull().unique(),
  name: text().notNull(),
});

// Table with indexes
export const posts = pgTable(
  'posts',
  {
    ...baseEntitySchema,
    title: text('title').notNull(),
    slug: text('slug').notNull(),
  },
  (table) => ({
    titleIdx: index('title_idx').on(table.title),
    slugIdx: uniqueIndex('slug_idx').on(table.slug),
  }),
);

// Table with composite key
export const userRoles = pgTable(
  'user_roles',
  {
    userId: text()
      .notNull()
      .references(() => users.id),
    roleId: text()
      .notNull()
      .references(() => roles.id),
    assignedAt: timestamp('assigned_at').notNull().defaultNow(),
  },
  (table) => ({
    pk: primaryKey(table.userId, table.roleId),
  }),
);
```

### Relations

```typescript
// One-to-many relation
export const postsRelations = relations(posts, ({ one }) => ({
  user: one(users, {
    fields: [posts.userId],
    references: [users.id],
  }),
}));

// One-to-one relation with cascade
export const userPreferences = pgTable('user_preferences', {
  userId: text()
    .primaryKey()
    .references(() => users.id, {
      onDelete: 'cascade',
      onUpdate: 'cascade',
    }),
  theme: text().notNull().default('light'),
  notifications: boolean().notNull().default(true),
});

// Many-to-many relations
export const userRolesRelations = relations(userRoles, ({ one }) => ({
  user: one(users, {
    fields: [userRoles.userId],
    references: [users.id],
  }),
  role: one(roles, {
    fields: [userRoles.roleId],
    references: [roles.id],
  }),
}));
```

## Database Operations

### Prepared Statements

```typescript
// Prepared statement for common queries
const getUserByEmail = db.query.users
  .findFirst({
    where: eq(users.email, sql.placeholder('email')),
  })
  .prepare();

// Usage
const user = await getUserByEmail.execute({ email: 'user@example.com' });
```

### Transactions

```typescript
// Basic transaction
const $createPostWithTags = createServerFn()
  .validator(postWithTagsSchema)
  .handler(async ({ data }) => {
    return await db.transaction(async (tx) => {
      const post = await tx.insert(posts).values(data.post);
      const tags = await tx.insert(tags).values(data.tags);
      return { success: true, data: { post, tags } };
    });
  });

// Batch operations in transaction
const $batchUpdateUsers = createServerFn()
  .validator(batchUpdateSchema)
  .handler(async ({ data }) => {
    return await db.transaction(async (tx) => {
      const updates = await Promise.all(
        data.map((user) =>
          tx.update(users).set(user).where(eq(users.id, user.id)),
        ),
      );
      return { success: true, data: updates };
    });
  });
```

### Error Handling

```typescript
// Handle database errors
try {
  const result = await db.insert(users).values(data);
  return { success: true, data: result };
} catch (error) {
  if (error instanceof UniqueConstraintError) {
    return {
      success: false,
      error: {
        code: 'DB_ERROR',
        message: 'Email already exists',
      },
    };
  }
  throw error;
}
```

## Migrations

### Migration File

```typescript
import { pgTable, serial, text, timestamp } from 'drizzle-orm/pg-core';

export async function up(db: Database) {
  await db.schema
    .createTable('posts')
    .addColumn('id', serial('id').primaryKey())
    .addColumn('title', text('title').notNull())
    .addColumn('content', text('content').notNull())
    .addColumn(
      'created_at',
      timestamp('created_at', { withTimezone: true }).notNull().defaultNow(),
    )
    .execute();
}

export async function down(db: Database) {
  await db.schema.dropTable('posts').execute();
}
```

### Migration Best Practices

1. Keep migrations small and focused
2. Use descriptive names (e.g., `001_create_users.ts`)
3. Always include down migrations
4. Test migrations thoroughly
5. Back up data before running in production
6. Use transactions for safety
7. Handle data transformations carefully

## Best Practices

1. Schema Design

   - Use appropriate data types
   - Add proper constraints
   - Implement indexes wisely
   - Follow naming conventions

2. Query Optimization

   - Use prepared statements
   - Implement proper indexes
   - Handle N+1 query problems
   - Use pagination for large datasets

3. Data Integrity

   - Use transactions when needed
   - Implement proper constraints
   - Handle cascading carefully
   - Validate data at boundaries

4. Security

   - Never trust user input
   - Use parameterized queries
   - Handle sensitive data properly
   - Implement proper access control

5. Performance
   - Monitor query performance
   - Use appropriate indexes
   - Implement caching when needed
   - Handle large datasets properly
