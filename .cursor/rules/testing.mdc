# Testing

See [Core Concepts](mdc:.cursor/rules/core.mdc) for project setup and general best practices.

## Test Organization

### File Structure

```sh
app/
├── components/
│   └── [Component]/
│       ├── index.tsx
│       └── [Component].test.tsx
├── features/
│   └── [feature]/
│       ├── api/
│       │   ├── queries.ts
│       │   └── queries.test.ts
│       └── components/
│           └── [Component]/
│               ├── index.tsx
│               └── [Component].test.tsx
└── lib/
    └── utils/
        ├── format.ts
        └── format.test.ts
```

### Test Structure

```typescript
import { describe, expect, it } from 'vitest';
import { render, screen } from '@testing-library/react';
import userEvent from '@testing-library/user-event';

describe('Feature: User Management', () => {
  describe('Component: UserForm', () => {
    it('should render form fields', () => {
      // Arrange
      render(<UserForm />);

      // Act
      const nameInput = screen.getByLabelText('Name');
      const emailInput = screen.getByLabelText('Email');

      // Assert
      expect(nameInput).toBeInTheDocument();
      expect(emailInput).toBeInTheDocument();
    });

    it('should handle form submission', async () => {
      // Arrange
      const onSubmit = vi.fn();
      render(<UserForm onSubmit={onSubmit} />);

      // Act
      await userEvent.type(screen.getByLabelText('Name'), 'John Doe');
      await userEvent.type(screen.getByLabelText('Email'), 'john@example.com');
      await userEvent.click(screen.getByRole('button', { name: /submit/i }));

      // Assert
      expect(onSubmit).toHaveBeenCalledWith({
        name: 'John Doe',
        email: 'john@example.com',
      });
    });
  });
});
```

## Component Testing

### Basic Component Tests

```typescript
import { render, screen } from '@testing-library/react';
import userEvent from '@testing-library/user-event';
import { Button } from './Button';

describe('Component: Button', () => {
  it('should render children', () => {
    render(<Button>Click me</Button>);
    expect(screen.getByText('Click me')).toBeInTheDocument();
  });

  it('should handle click events', async () => {
    const onClick = vi.fn();
    render(<Button onClick={onClick}>Click me</Button>);

    await userEvent.click(screen.getByRole('button'));
    expect(onClick).toHaveBeenCalled();
  });

  it('should be disabled when loading', () => {
    render(<Button isLoading>Click me</Button>);
    expect(screen.getByRole('button')).toBeDisabled();
  });
});
```

### Form Testing

```typescript
import { render, screen } from '@testing-library/react';
import userEvent from '@testing-library/user-event';
import { UserForm } from './UserForm';

describe('Component: UserForm', () => {
  const defaultProps = {
    onSubmit: vi.fn(),
    defaultValues: {
      name: '',
      email: '',
    },
  };

  it('should validate required fields', async () => {
    render(<UserForm {...defaultProps} />);

    await userEvent.click(screen.getByRole('button', { name: /submit/i }));

    expect(screen.getByText('Name is required')).toBeInTheDocument();
    expect(screen.getByText('Email is required')).toBeInTheDocument();
  });

  it('should validate email format', async () => {
    render(<UserForm {...defaultProps} />);

    await userEvent.type(screen.getByLabelText('Email'), 'invalid-email');
    await userEvent.click(screen.getByRole('button', { name: /submit/i }));

    expect(screen.getByText('Invalid email address')).toBeInTheDocument();
  });

  it('should call onSubmit with form data', async () => {
    render(<UserForm {...defaultProps} />);

    await userEvent.type(screen.getByLabelText('Name'), 'John Doe');
    await userEvent.type(screen.getByLabelText('Email'), 'john@example.com');
    await userEvent.click(screen.getByRole('button', { name: /submit/i }));

    expect(defaultProps.onSubmit).toHaveBeenCalledWith({
      name: 'John Doe',
      email: 'john@example.com',
    });
  });
});
```

## API Testing

### Server Function Tests

```typescript
import { describe, expect, it, vi } from 'vitest';
import { db } from '~/lib/db';
import { $createUser } from './users.api';

vi.mock('~/lib/db', () => ({
  db: {
    insert: vi.fn(),
    select: vi.fn(),
  },
}));

describe('API: Users', () => {
  afterEach(() => {
    vi.clearAllMocks();
  });

  it('should create user', async () => {
    const userData = {
      name: 'John Doe',
      email: 'john@example.com',
    };

    vi.mocked(db.insert).mockResolvedValueOnce([userData]);

    const result = await $createUser({ data: userData });

    expect(result.success).toBe(true);
    expect(result.data).toEqual(userData);
    expect(db.insert).toHaveBeenCalledWith(expect.any(Object), userData);
  });

  it('should handle validation errors', async () => {
    const result = await $createUser({
      data: { name: '', email: 'invalid' },
    });

    expect(result.success).toBe(false);
    expect(result.error?.code).toBe('VALIDATION_ERROR');
  });

  it('should handle unique constraint errors', async () => {
    vi.mocked(db.insert).mockRejectedValueOnce(
      new Error('duplicate key value violates unique constraint'),
    );

    const result = await $createUser({
      data: { name: 'John', email: 'existing@example.com' },
    });

    expect(result.success).toBe(false);
    expect(result.error?.code).toBe('DUPLICATE_EMAIL');
  });
});
```

### Query Tests

```typescript
import { renderHook, waitFor } from '@testing-library/react';
import { useQuery } from '@tanstack/react-query';
import { server } from '~/mocks/server';
import { http, HttpResponse } from 'msw';

describe('Query: Users', () => {
  it('should fetch users', async () => {
    server.use(
      http.get('/api/users', () => {
        return HttpResponse.json([
          { id: '1', name: 'John' },
          { id: '2', name: 'Jane' },
        ]);
      }),
    );

    const { result } = renderHook(() => useQuery(userQueryOptions()));

    await waitFor(() => expect(result.current.isSuccess).toBe(true));

    expect(result.current.data).toHaveLength(2);
  });

  it('should handle error states', async () => {
    server.use(
      http.get('/api/users', () => {
        return HttpResponse.error();
      }),
    );

    const { result } = renderHook(() => useQuery(userQueryOptions()));

    await waitFor(() => expect(result.current.isError).toBe(true));
  });
});
```

## Integration Testing

### Route Tests

```typescript
import { render, screen } from '@testing-library/react';
import { createMemoryRouter, RouterProvider } from '@tanstack/react-router';
import { routes } from '~/routes';

describe('Route: Users', () => {
  it('should render users list', async () => {
    const router = createMemoryRouter({
      routes,
      initialEntries: ['/users'],
    });

    render(<RouterProvider router={router} />);

    expect(await screen.findByRole('heading', { name: /users/i })).toBeInTheDocument();
    expect(await screen.findAllByRole('row')).toHaveLength(10);
  });

  it('should handle pagination', async () => {
    const router = createMemoryRouter({
      routes,
      initialEntries: ['/users?page=2'],
    });

    render(<RouterProvider router={router} />);

    expect(await screen.findByRole('button', { name: /page 2/i })).toHaveAttribute('aria-current', 'page');
  });
});
```

### Form Flow Tests

```typescript
import { render, screen } from '@testing-library/react';
import userEvent from '@testing-library/user-event';
import { CreateUserFlow } from './CreateUserFlow';

describe('Flow: Create User', () => {
  it('should complete user creation flow', async () => {
    render(<CreateUserFlow />);

    // Step 1: Basic Info
    await userEvent.type(screen.getByLabelText('Name'), 'John Doe');
    await userEvent.type(screen.getByLabelText('Email'), 'john@example.com');
    await userEvent.click(screen.getByRole('button', { name: /next/i }));

    // Step 2: Role Selection
    await userEvent.click(screen.getByRole('radio', { name: /admin/i }));
    await userEvent.click(screen.getByRole('button', { name: /next/i }));

    // Step 3: Confirmation
    expect(screen.getByText('john@example.com')).toBeInTheDocument();
    expect(screen.getByText('Admin')).toBeInTheDocument();

    await userEvent.click(screen.getByRole('button', { name: /confirm/i }));

    // Success state
    expect(screen.getByText(/user created successfully/i)).toBeInTheDocument();
  });
});
```

## Test Setup

### Setup Files

```typescript
// setup/setup-tests.ts
import { afterEach, beforeAll, afterAll } from 'vitest';
import { cleanup } from '@testing-library/react';
import { server } from './mocks/server';
import '@testing-library/jest-dom/vitest';

// Setup MSW
beforeAll(() => server.listen({ onUnhandledRequest: 'error' }));
afterEach(() => {
  cleanup();
  server.resetHandlers();
});
afterAll(() => server.close());

// Global test setup
global.ResizeObserver = vi.fn().mockImplementation(() => ({
  observe: vi.fn(),
  unobserve: vi.fn(),
  disconnect: vi.fn(),
}));

// Mock IntersectionObserver
global.IntersectionObserver = vi.fn().mockImplementation(() => ({
  observe: vi.fn(),
  unobserve: vi.fn(),
  disconnect: vi.fn(),
}));
```

### Test Utils

```typescript
// test-utils.tsx
import { render } from '@testing-library/react';
import { QueryClient, QueryClientProvider } from '@tanstack/react-query';
import { createMemoryRouter, RouterProvider } from '@tanstack/react-router';

const queryClient = new QueryClient({
  defaultOptions: {
    queries: {
      retry: false,
    },
  },
});

export function renderWithProviders(ui: React.ReactElement) {
  return render(
    <QueryClientProvider client={queryClient}>{ui}</QueryClientProvider>,
  );
}

export function renderRoute(route: string) {
  const router = createMemoryRouter({
    routes,
    initialEntries: [route],
  });

  return render(<RouterProvider router={router} />);
}
```

## Best Practices

1. Test Organization

   - Place tests next to code
   - Use descriptive test names
   - Follow AAA pattern
   - Group related tests

2. Component Testing

   - Test behavior, not implementation
   - Use proper queries
   - Test accessibility
   - Handle async operations

3. API Testing

   - Mock external dependencies
   - Test error cases
   - Validate responses
   - Clean up after tests

4. Integration Testing

   - Test critical flows
   - Mock network requests
   - Test error scenarios
   - Verify state changes

5. Performance
   - Mock heavy operations
   - Clean up resources
   - Use proper setup/teardown
   - Optimize test runs
