# Component Patterns

## Component Types

1. **UI Components**

   - Buttons, Inputs, Cards
   - Layout components
   - Navigation elements
   - Feedback components

2. **Feature Components**

   - Business logic
   - Data fetching
   - State management
   - User interactions

3. **Layout Components**

   - Page layouts
   - Grid systems
   - Container components
   - Responsive layouts

4. **Composite Components**

   - Forms
   - Data tables
   - Complex UIs
   - Multi-step flows

## Component Structure

### Base Component

```typescript
// app/components/[ComponentName]/index.ts
export { ComponentName } from './ComponentName';
export type { ComponentProps } from './types';

// app/components/[ComponentName]/types.ts
export interface ComponentProps {
  className?: string;
  children?: React.ReactNode;
}

// app/components/[ComponentName]/ComponentName.tsx
import { cn } from '~/lib/utils';
import { ComponentProps } from './types';
import { useComponentLogic } from './use-component-logic';

export function ComponentName({
  className,
  children,
  ...props
}: ComponentProps) {
  const { state, handlers } = useComponentLogic(props);

  return (
    <div className={cn('base-styles', className)} {...props}>
      {children}
    </div>
  );
}
```

### Component with Logic

```typescript
// Feature component with data and logic
export function UserProfile({ userId }: { userId: string }) {
  // Data fetching
  const { data: user, isLoading, error } = useUser(userId);

  // Event handlers
  const handleUpdate = useCallback(async (data: UpdateUserData) => {
    // Handle update
  }, []);

  // Loading state
  if (isLoading) {
    return <UserProfileSkeleton />;
  }

  // Error state
  if (error) {
    return <ErrorCard error={error} />;
  }

  // Empty state
  if (!user) {
    return <EmptyState message="User not found" />;
  }

  // Success state
  return (
    <Card>
      <UserInfo user={user} onUpdate={handleUpdate} />
    </Card>
  );
}
```

## Component Patterns

### Data Display

```typescript
// Table with sorting and pagination
export function DataTable<TData>({
  data,
  columns,
  pagination,
}: DataTableProps<TData>) {
  const table = useReactTable({
    data,
    columns,
    getCoreRowModel: getCoreRowModel(),
  });

  return (
    <div className="relative">
      <Table>
        <TableHeader>
          {table.getHeaderGroups().map((headerGroup) => (
            <TableRow key={headerGroup.id}>
              {headerGroup.headers.map((header) => (
                <TableHead key={header.id}>
                  {flexRender(
                    header.column.columnDef.header,
                    header.getContext(),
                  )}
                </TableHead>
              ))}
            </TableRow>
          ))}
        </TableHeader>
        <TableBody>
          {table.getRowModel().rows.map((row) => (
            <TableRow key={row.id}>
              {row.getVisibleCells().map((cell) => (
                <TableCell key={cell.id}>
                  {flexRender(
                    cell.column.columnDef.cell,
                    cell.getContext(),
                  )}
                </TableCell>
              ))}
            </TableRow>
          ))}
        </TableBody>
      </Table>
      {pagination && (
        <DataTablePagination {...pagination} />
      )}
    </div>
  );
}
```

### Feedback Components

```typescript
// Loading states
export function LoadingSpinner({
  size = 'md',
  className
}: LoadingSpinnerProps) {
  return (
    <div
      className={cn(
        'animate-spin rounded-full border-2 border-current border-t-transparent',
        {
          'h-4 w-4': size === 'sm',
          'h-6 w-6': size === 'md',
          'h-8 w-8': size === 'lg',
        },
        className
      )}
      role="status"
      aria-label="Loading"
    />
  );
}

// Empty state with action
export function EmptyState({
  icon: Icon,
  title,
  description,
  action,
}: EmptyStateProps) {
  return (
    <div className="flex flex-col items-center p-8 text-center">
      <Icon className="h-12 w-12 text-muted-foreground" />
      <h3 className="mt-4 font-medium">{title}</h3>
      <p className="text-sm text-muted-foreground">{description}</p>
      {action && <div className="mt-4">{action}</div>}
    </div>
  );
}
```

### i18n Components

```typescript
// Basic component with translations
function WelcomeMessage() {
  const { t } = useTranslation();
  return <h1>{t('common:welcome')}</h1>;
}

// Component with namespace
function LoginForm() {
  const { t } = useTranslation('auth');

  return (
    <form className="space-y-4">
      <div>
        <label>{t('emailLabel')}</label>
        <input
          type="email"
          placeholder={t('emailPlaceholder')}
          aria-label={t('emailLabel')}
        />
      </div>
      <div>
        <label>{t('passwordLabel')}</label>
        <input
          type="password"
          placeholder={t('passwordPlaceholder')}
          aria-label={t('passwordLabel')}
        />
      </div>
      <Button type="submit">
        {t('loginButton')}
      </Button>
    </form>
  );
}

// Component with interpolation
function UserGreeting({ name, count }: { name: string; count: number }) {
  const { t } = useTranslation();
  return (
    <div>
      {t('greeting', { name })}
      {t('notifications', { count })}
    </div>
  );
}

// Language switcher component
function LanguageSwitcher() {
  const { i18n } = useTranslation();
  const router = useRouter();

  const handleLanguageChange = async (lng: string) => {
    const translations = await getServerSideTranslations({
      lng,
      namespaces: ['common', 'auth'],
    });

    Object.entries(translations).forEach(([ns, resources]) => {
      i18n.addResourceBundle(lng, ns, resources, true, true);
    });

    await i18n.changeLanguage(lng);
    router.reload();
  };

  return (
    <Select
      value={i18n.language}
      onValueChange={handleLanguageChange}
    >
      <SelectTrigger>
        <SelectValue />
      </SelectTrigger>
      <SelectContent>
        <SelectItem value="en">English</SelectItem>
        <SelectItem value="es">Español</SelectItem>
        <SelectItem value="fr">Français</SelectItem>
      </SelectContent>
    </Select>
  );
}

// Component with dynamic namespace loading
function FeatureComponent() {
  const namespace = 'feature';
  const { t } = useTranslation();
  const { isLoading } = useLoadTranslations(namespace);

  if (isLoading) {
    return <div>{t('common:loading')}</div>;
  }

  return <div>{t(`${namespace}:title`)}</div>;
}

// HOC for translation loading
function withTranslations<P extends object>(
  WrappedComponent: React.ComponentType<P>,
  namespace: string
) {
  return function TranslatedComponent(props: P) {
    const { t } = useTranslation();
    const { isLoading } = useLoadTranslations(namespace);

    if (isLoading) {
      return <div>{t('common:loading')}</div>;
    }

    return <WrappedComponent {...props} />;
  };
}
```

### i18n Component Best Practices

1. **Component Organization**

   - Keep translations close to components
   - Use proper namespacing
   - Handle loading states
   - Provide fallback content
   - Support dynamic loading

2. **Type Safety**

   - Use translation key types
   - Type interpolation values
   - Handle missing translations
   - Validate translation keys
   - Type-safe components

3. **Performance**

   - Load translations on demand
   - Cache translation results
   - Memoize translation functions
   - Handle suspense boundaries
   - Optimize bundle size

4. **Accessibility**
   - Use proper HTML lang attribute
   - Support RTL languages
   - Handle screen readers
   - Manage focus on language change
   - Provide aria labels

## Component Best Practices

1. **Component Design**

   - Single responsibility
   - Composable interfaces
   - Proper prop types
   - Consistent styling
   - Accessibility first

2. **State Management**

   - Controlled vs uncontrolled
   - Prop drilling vs context
   - Server state vs client state
   - Form state handling
   - Loading states

3. **Performance**

   - Proper memoization
   - Lazy loading
   - Code splitting
   - Bundle optimization
   - Render optimization

4. **Error Handling**

   - Error boundaries
   - Loading states
   - Empty states
   - Error messages
   - Recovery actions

5. **Accessibility**

   - ARIA attributes
   - Keyboard navigation
   - Screen reader support
   - Color contrast
   - Focus management

