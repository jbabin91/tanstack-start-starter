# Form Patterns

## Form Types

1. **Basic Forms**

   - Login/Register
   - Search forms
   - Filter forms
   - Simple inputs

2. **Complex Forms**

   - Multi-step forms
   - Dynamic forms
   - Nested forms
   - Array fields

3. **Specialized Forms**
   - File upload
   - Rich text
   - Date/time
   - Autocomplete

## Form Structure

### Basic Form

```typescript
// Types
type FormField<T> = {
  name: string;
  value: T;
  error?: string;
  touched: boolean;
};

type FormState<T> = {
  values: T;
  errors: Partial<Record<keyof T, string[]>>;
  touched: Partial<Record<keyof T, boolean>>;
  isSubmitting: boolean;
  isValid: boolean;
};

type LoginFormData = {
  email: string;
  password: string;
};

type RegistrationFormData = {
  // Step 1: Account
  email: string;
  password: string;
  // Step 2: Profile
  name: string;
  bio: string;
  // Step 3: Preferences
  notifications: boolean;
  theme: 'light' | 'dark';
};

type DynamicFieldData = {
  name: string;
  value: string;
};

type DynamicFormData = {
  fields: DynamicFieldData[];
};

// Basic form with validation
export function LoginForm() {
  const form = createForm<LoginFormData>({
    defaultValues: {
      email: '',
      password: '',
    },
    validatorSchema: loginSchema,
    onSubmit: async ({ value }) => {
      try {
        await $login(value);
        toast.success('Logged in successfully');
        router.navigate('/dashboard');
      } catch (error) {
        if (error instanceof ValidationError) {
          form.setErrors(error.fields);
          return;
        }
        throw error;
      }
    },
  });

  return (
    <form.Provider>
      <form onSubmit={form.handleSubmit} className="space-y-4">
        <form.Field name="email">
          {(field) => (
            <FormField label="Email" error={field.state.meta.errors?.[0]}>
              <Input {...field.props} type="email" autoComplete="email" />
            </FormField>
          )}
        </form.Field>

        <form.Field name="password">
          {(field) => (
            <FormField label="Password" error={field.state.meta.errors?.[0]}>
              <Input {...field.props} type="password" autoComplete="current-password" />
            </FormField>
          )}
        </form.Field>

        <Button type="submit" disabled={form.state.isSubmitting}>
          {form.state.isSubmitting ? 'Logging in...' : 'Log in'}
        </Button>
      </form>
    </form.Provider>
  );
}
```

### Multi-step Form

```typescript
// Multi-step form with validation
export function RegistrationForm() {
  const [step, setStep] = useState(1);

  const form = createForm<RegistrationFormData>({
    defaultValues: {
      email: '',
      password: '',
      name: '',
      bio: '',
      notifications: true,
      theme: 'light',
    },
    validatorSchema: registrationSchema,
  });

  const nextStep = async () => {
    const stepValid = await form.validateFields(
      step === 1 ? ['email', 'password'] : step === 2 ? ['name', 'bio'] : ['notifications', 'theme']
    );

    if (stepValid) {
      setStep((s) => Math.min(s + 1, 3));
    }
  };

  const prevStep = () => {
    setStep((s) => Math.max(s - 1, 1));
  };

  return (
    <form.Provider>
      <form onSubmit={form.handleSubmit} className="space-y-6">
        {step === 1 && <AccountStep form={form} onNext={nextStep} />}
        {step === 2 && <ProfileStep form={form} onNext={nextStep} onPrev={prevStep} />}
        {step === 3 && <PreferencesStep form={form} onPrev={prevStep} onSubmit={form.handleSubmit} />}
      </form>
    </form.Provider>
  );
}
```

### Form Validation

```typescript
// Validation schema with Zod
const userSchema = z
  .object({
    email: z.string().email('Invalid email address').min(1, 'Email is required'),
    password: z
      .string()
      .min(8, 'Password must be at least 8 characters')
      .regex(/^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)/, 'Password must contain uppercase, lowercase, and number'),
    confirmPassword: z.string(),
  })
  .refine((data) => data.password === data.confirmPassword, {
    message: 'Passwords do not match',
    path: ['confirmPassword'],
  });

// Custom field validation
export function PasswordField() {
  const form = useFormContext();

  return (
    <form.Field
      name="password"
      validate={async (value) => {
        // Check password strength
        const strength = await checkPasswordStrength(value);
        if (strength < 0.7) {
          return 'Password is too weak';
        }
      }}
    >
      {(field) => (
        <FormField label="Password" error={field.state.meta.errors?.[0]}>
          <PasswordInput {...field.props} />
          <PasswordStrengthMeter value={field.state.value} />
        </FormField>
      )}
    </form.Field>
  );
}
```

### Dynamic Forms

```typescript
// Dynamic form with validation
export function DynamicForm() {
  const form = createForm<DynamicFormData>({
    defaultValues: {
      fields: [{ name: '', value: '' }],
    },
  });

  return (
    <form.Provider>
      <form onSubmit={form.handleSubmit}>
        <form.Field name="fields">
          {(field) => (
            <div className="space-y-4">
              {field.state.value.map((_, index) => (
                <div key={index} className="flex gap-2">
                  <form.Field name={`fields.${index}.name`} defaultValue="">
                    {(nameField) => (
                      <FormField label="Name" error={nameField.state.meta.errors?.[0]}>
                        <Input {...nameField.props} />
                      </FormField>
                    )}
                  </form.Field>
                  <form.Field name={`fields.${index}.value`} defaultValue="">
                    {(valueField) => (
                      <FormField label="Value" error={valueField.state.meta.errors?.[0]}>
                        <Input {...valueField.props} />
                      </FormField>
                    )}
                  </form.Field>
                  <Button
                    type="button"
                    variant="ghost"
                    onClick={() => field.removeValue(index)}
                    className="mt-8"
                  >
                    Remove
                  </Button>
                </div>
              ))}
              <Button type="button" onClick={() => field.pushValue({ name: '', value: '' })}>
                Add Field
              </Button>
            </div>
          )}
        </form.Field>
      </form>
    </form.Provider>
  );
}
```

## Form Best Practices

1. **Form Design**

   - Clear structure
   - Logical grouping
   - Progressive disclosure
   - Proper validation
   - Error feedback

2. **User Experience**

   - Instant validation
   - Clear feedback
   - Helpful messages
   - Proper tabbing
   - Auto-complete

3. **Performance**

   - Debounced validation
   - Optimized rendering
   - Proper field isolation
   - Efficient updates
   - Controlled inputs

4. **Accessibility**

   - Proper labels
   - Error association
   - Keyboard navigation
   - Screen reader support
   - Focus management

5. **Security**
   - Input sanitization
   - CSRF protection
   - Rate limiting
   - Validation
   - Error handling

