# State Management Patterns

## State Hierarchy

1. **URL State** (TanStack Router)

   - Source of truth for route state
   - Search parameters
   - Route parameters
   - Navigation state
   - Shareable state

2. **Global State** (Zustand)

   - Authentication
   - Theme preferences
   - Feature flags
   - App settings
   - Global UI state

3. **Server State** (TanStack Query)

   - Remote data
   - Cache management
   - Mutations
   - Real-time updates
   - Optimistic updates

4. **Form State** (TanStack Form)

   - Form values
   - Validation
   - Submission
   - Field arrays
   - Form errors

5. **Local State** (React)
   - Component state
   - UI interactions
   - Temporary data
   - Derived state

## State Patterns

### URL State (TanStack Router)

```typescript
// Route with search params and nested data
export const Route = createFileRoute('/users')({
  validateSearch: z.object({
    sort: z.enum(['asc', 'desc']).default('desc'),
    filter: z.enum(['all', 'active', 'inactive']).default('all'),
    page: z.coerce.number().min(1).default(1),
    query: z.string().optional(),
  }),

  // Loader with dependent data
  loader: async ({ search, context: { queryClient } }) => ({
    users: await queryClient.ensureQueryData(
      queryOptions({
        queryKey: ['users', search],
        queryFn: () => $getUsers(search),
      }),
    ),
    filters: await queryClient.ensureQueryData(
      queryOptions({
        queryKey: ['filters'],
        queryFn: () => $getFilters(),
      }),
    ),
  }),

  // Component with URL state management
  component: UsersPage,
});

function UsersPage() {
  const { search, setSearch } = useSearch();
  const { users, filters } = useLoaderData();

  // URL-driven filters
  const handleFilterChange = (filter: string) => {
    setSearch({ filter, page: 1 }); // Reset page on filter change
  };

  // URL-driven search
  const handleSearch = useDebouncedCallback((query: string) => {
    setSearch({ query, page: 1 }); // Reset page on search
  }, 300);

  return (
    <div>
      <SearchInput
        value={search.query}
        onChange={handleSearch}
      />
      <FilterTabs
        value={search.filter}
        onChange={handleFilterChange}
        filters={filters}
      />
      <DataTable data={users.items} />
      <Pagination
        page={search.page}
        onChange={(page) => setSearch({ page })}
      />
    </div>
  );
}
```

### Global State (Zustand)

```typescript
type AuthState = {
  user: User | null;
  isAuthenticated: boolean;
  setUser: (user: User | null) => void;
  logout: () => Promise<void>;
};

type SettingsState = {
  theme: 'light' | 'dark' | 'system';
  language: string;
  setTheme: (theme: Theme) => void;
  setLanguage: (language: string) => void;
};

type Theme = 'light' | 'dark' | 'system';

type User = {
  id: string;
  name: string;
  email: string;
  role: 'user' | 'admin';
};

type UserFormData = {
  name: string;
  email: string;
  role: 'user' | 'admin';
};

// Example auth store with types
export const useAuthStore = create<AuthState>()(
  persist(
    (set) => ({
      user: null,
      isAuthenticated: false,
      setUser: (user) => set({ user, isAuthenticated: !!user }),
      logout: async () => {
        await $logout();
        set({ user: null, isAuthenticated: false });
        queryClient.clear();
        router.navigate('/login');
      },
    }),
    { name: 'auth' },
  ),
);

// Example settings store with types
export const useSettingsStore = create<SettingsState>()(
  persist(
    (set) => ({
      theme: 'system',
      language: 'en',
      setTheme: (theme) => {
        set({ theme });
        document.documentElement.setAttribute('data-theme', theme);
      },
      setLanguage: (language) => {
        set({ language });
        document.documentElement.setAttribute('lang', language);
      },
    }),
    { name: 'settings' },
  ),
);
```

