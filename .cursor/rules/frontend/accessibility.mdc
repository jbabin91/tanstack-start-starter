## Component Patterns

### Semantic Structure

```typescript
// Page layout with landmarks
export function Layout({ children }: LayoutProps) {
  return (
    <div className="min-h-screen">
      <a href="#main" className="sr-only focus:not-sr-only">
        Skip to main content
      </a>

      <header role="banner">
        <nav role="navigation" aria-label="Main">
          <MainNav />
        </nav>
      </header>

      <main id="main" role="main" tabIndex={-1}>
        {children}
      </main>

      <footer role="contentinfo">
        <FooterContent />
      </footer>
    </div>
  );
}

// Section with proper headings
export function Section({
  title,
  description,
  children,
}: SectionProps) {
  return (
    <section
      aria-labelledby="section-title"
      className="space-y-4"
    >
      <div className="space-y-1">
        <h2 id="section-title" className="text-2xl font-bold">
          {title}
        </h2>
        {description && (
          <p className="text-muted-foreground">{description}</p>
        )}
      </div>
      {children}
    </section>
  );
}
```

### Interactive Components

```typescript
// Accessible button with loading state
export function Button({
  children,
  isLoading,
  ...props
}: ButtonProps) {
  return (
    <button
      {...props}
      disabled={isLoading || props.disabled}
      aria-busy={isLoading}
      className={cn(
        'inline-flex items-center justify-center',
        isLoading && 'cursor-wait opacity-50',
        props.className
      )}
    >
      {isLoading && (
        <Spinner
          className="mr-2 h-4 w-4"
          aria-hidden="true"
        />
      )}
      {children}
    </button>
  );
}

// Dialog with proper focus management
export function Dialog({
  title,
  description,
  children,
  ...props
}: DialogProps) {
  return (
    <DialogPrimitive.Root {...props}>
      <DialogPrimitive.Portal>
        <DialogPrimitive.Overlay
          className="fixed inset-0 bg-black/50"
          aria-hidden="true"
        />
        <DialogPrimitive.Content
          className="fixed left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2"
          aria-labelledby="dialog-title"
          aria-describedby="dialog-description"
        >
          <h2 id="dialog-title" className="text-lg font-bold">
            {title}
          </h2>
          {description && (
            <p id="dialog-description" className="text-muted-foreground">
              {description}
            </p>
          )}
          {children}
          <DialogPrimitive.Close
            aria-label="Close"
            className="absolute right-4 top-4"
          >
            <XIcon className="h-4 w-4" />
          </DialogPrimitive.Close>
        </DialogPrimitive.Content>
      </DialogPrimitive.Portal>
    </DialogPrimitive.Root>
  );
}
```

### Form Components

```typescript
// Accessible form field
export function FormField({
  label,
  error,
  required,
  children,
}: FormFieldProps) {
  const id = useId();
  const errorId = useId();

  return (
    <div className="space-y-2">
      <Label
        htmlFor={id}
        className={cn(required && 'after:content-["*"] after:ml-1 after:text-destructive')}
      >
        {label}
      </Label>
      {React.Children.map(children, (child) => {
        if (!React.isValidElement(child)) return child;
        return React.cloneElement(child, {
          id,
          'aria-describedby': error ? errorId : undefined,
          'aria-invalid': !!error,
          'aria-required': required,
        });
      })}
      {error && (
        <p
          id={errorId}
          className="text-sm text-destructive"
          role="alert"
        >
          {error}
        </p>
      )}
    </div>
  );
}

// Accessible select
export function Select({
  label,
  options,
  error,
  ...props
}: SelectProps) {
  const id = useId();
  const errorId = useId();

  return (
    <div className="space-y-2">
      <Label htmlFor={id}>{label}</Label>
      <SelectPrimitive.Root {...props}>
        <SelectPrimitive.Trigger
          id={id}
          aria-describedby={error ? errorId : undefined}
          aria-invalid={!!error}
          className={cn(
            'border rounded-md px-3 py-2',
            error && 'border-destructive'
          )}
        >
          <SelectPrimitive.Value placeholder="Select an option" />
        </SelectPrimitive.Trigger>
        <SelectPrimitive.Portal>
          <SelectPrimitive.Content>
            <SelectPrimitive.Viewport>
              {options.map((option) => (
                <SelectPrimitive.Item
                  key={option.value}
                  value={option.value}
                >
                  <SelectPrimitive.ItemText>
                    {option.label}
                  </SelectPrimitive.ItemText>
                </SelectPrimitive.Item>
              ))}
            </SelectPrimitive.Viewport>
          </SelectPrimitive.Content>
        </SelectPrimitive.Portal>
      </SelectPrimitive.Root>
      {error && (
        <p
          id={errorId}
          className="text-sm text-destructive"
          role="alert"
        >
          {error}
        </p>
      )}
    </div>
  );
}
```

### Status and Updates

```typescript
// Live region for status updates
export function StatusMessage({
  message,
  type = 'status',
}: StatusMessageProps) {
  return (
    <div
      role={type === 'alert' ? 'alert' : 'status'}
      aria-live={type === 'alert' ? 'assertive' : 'polite'}
      className={cn(
        'p-4 rounded-md',
        type === 'alert' && 'bg-destructive text-destructive-foreground',
        type === 'status' && 'bg-muted'
      )}
    >
      {message}
    </div>
  );
}

// Loading state
export function LoadingState({
  children,
  isLoading,
}: LoadingStateProps) {
  return (
    <div aria-busy={isLoading}>
      {isLoading ? (
        <div
          role="status"
          className="flex items-center justify-center p-4"
        >
          <Spinner className="h-6 w-6" />
          <span className="ml-2">Loading...</span>
        </div>
      ) : (
        children
      )}
    </div>
  );
}
```

## Best Practices

1. **Semantic HTML**

   - Use proper HTML elements
   - Implement ARIA landmarks
   - Maintain heading hierarchy
   - Provide skip links

2. **Keyboard Navigation**

   - Ensure focusability
   - Logical tab order
   - Focus management
   - Keyboard shortcuts

3. **ARIA Usage**

   - Follow ARIA patterns
   - Proper role usage
   - State management
   - Live regions

4. **Visual Design**

   - Color contrast
   - Focus indicators
   - Text sizing
   - Spacing

5. **Content**
   - Alt text
   - Error messages
   - Status updates
   - Instructions

## Testing Patterns

```typescript
// Accessibility test utilities
export const a11y = {
  // Check focus management
  async checkFocus(element: HTMLElement) {
    expect(document.activeElement).toBe(element);
  },

  // Check ARIA attributes
  checkAriaLabel(element: HTMLElement, label: string) {
    expect(element).toHaveAttribute('aria-label', label);
  },

  // Check keyboard navigation
  async pressTab(times = 1) {
    for (let i = 0; i < times; i++) {
      await userEvent.tab();
    }
  },

  // Check screen reader text
  checkScreenReaderText(text: string) {
    expect(screen.getByText(text)).toHaveClass('sr-only');
  },
};

// Component tests
describe('Dialog', () => {
  it('manages focus correctly', async () => {
    render(<Dialog />);

    // Open dialog
    await userEvent.click(screen.getByRole('button'));

    // Check focus trap
    await a11y.checkFocus(screen.getByRole('dialog'));

    // Check focus movement
    await a11y.pressTab();
    await a11y.checkFocus(screen.getByRole('button', { name: 'Close' }));
  });

  it('has proper ARIA attributes', () => {
    render(<Dialog title="Test" description="Test description" />);

    const dialog = screen.getByRole('dialog');
    expect(dialog).toHaveAttribute('aria-labelledby');
    expect(dialog).toHaveAttribute('aria-describedby');
  });
});
```

