type UserSchema = {
id: number;
email: string;
name: string;
age: number;
role: 'user' | 'admin';
};

type ValidationError = {
path: string[];
message: string;
code: string;
};

type ValidationResult<T> = {
success: boolean;
data?: T;
errors?: ValidationError[];
};

// Basic schema validation
const userSchema = z.object({
email: z.string().email(),
name: z.string().min(2),
age: z.number().min(18),
role: z.enum(['user', 'admin']),
});

// Custom validator type
type CustomValidator<T> = (value: T) => ValidationResult<T>;

// Form validation type
type FormValidation<T> = {
values: T;
errors: Partial<Record<keyof T, string>>;
touched: Partial<Record<keyof T, boolean>>;
};

// API validation type
type APIValidation<T> = {
input: unknown;
output: ValidationResult<T>;
};
