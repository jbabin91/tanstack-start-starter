## Mutation Composition

### 1. Sequential Mutations

```typescript
// Sequential mutations hook
export function usePublishPost() {
  const updatePost = useUpdatePost();
  const notifySubscribers = useNotifySubscribers();

  const publish = async (postId: number): Promise<PublishPostResult> => {
    // First update the post
    const post = await updatePost.mutateAsync({
      id: postId,
      data: { published: true },
    });

    // Then notify subscribers
    const notification = post.published
      ? await notifySubscribers.mutateAsync({
          postId: post.id,
          type: 'new_post',
        })
      : null;

    return { post, notification };
  };

  return {
    publish,
    isLoading: updatePost.isLoading || notifySubscribers.isLoading,
    error: updatePost.error || notifySubscribers.error,
  };
}
```

### 2. Coordinated Mutations

```typescript
// Coordinated mutations hook
export function useUpdatePostWithTags() {
  const queryClient = useQueryClient();
  const updatePost = useUpdatePost();
  const updateTags = useUpdateTags();

  return useMutation({
    mutationFn: async ({
      postId,
      data,
      tags,
    }: UpdatePostWithTagsData): Promise<UpdatePostWithTagsResult> => {
      return db.transaction(async (tx) => {
        const [post] = await updatePost.mutateAsync({ id: postId, data });
        const updatedTags = await updateTags.mutateAsync({
          postId,
          tags,
        });
        return { post, tags: updatedTags };
      });
    },
    onSuccess: ({ post, tags }) => {
      queryClient.setQueryData(['post', post.id], {
        ...post,
        tags,
      });
    },
  });
}
```

