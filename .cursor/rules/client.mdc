## Component Patterns

### 1. Base Component Pattern

```typescript
type BaseProps = {
  className?: string;
  children?: React.ReactNode;
};

// Basic UI Component
type ButtonProps = BaseProps & {
  variant?: 'default' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  isLoading?: boolean;
  onClick?: () => void;
};

export function Button({
  variant = 'default',
  size = 'md',
  isLoading,
  className,
  children,
  onClick,
}: ButtonProps) {
  return (
    <button
      className={cn(
        buttonVariants({ variant, size }),
        className
      )}
      onClick={onClick}
      disabled={isLoading}
    >
      {isLoading ? (
        <Loader2 className="size-4 animate-spin me-2" />
      ) : children}
    </button>
  );
}
```

### 2. Data Display Pattern

```typescript
type DataDisplayProps<T> = BaseProps & {
  data: T;
  isLoading?: boolean;
  error?: Error;
  renderItem: (item: T) => React.ReactNode;
};

export function DataDisplay<T>({
  data,
  isLoading,
  error,
  renderItem,
  className,
}: DataDisplayProps<T>) {
  if (isLoading) {
    return <LoadingSkeleton className={className} />;
  }

  if (error) {
    return (
      <ErrorMessage
        error={error}
        className={className}
      />
    );
  }

  return (
    <div className={cn("space-y-4", className)}>
      {renderItem(data)}
    </div>
  );
}
```

### 3. Form Pattern

```typescript
type FormProps<T> = BaseProps & {
  defaultValues?: Partial<T>;
  onSubmit: (data: T) => Promise<void>;
  onSuccess?: () => void;
};

export function Form<T>({
  defaultValues,
  onSubmit,
  onSuccess,
  children,
  className,
}: FormProps<T>) {
  const form = createForm({
    defaultValues,
    onSubmit: async ({ value }) => {
      try {
        await onSubmit(value);
        toast.success('Success');
        onSuccess?.();
      } catch (error) {
        toast.error(error instanceof Error ? error.message : 'Error');
      }
    },
  });

  return (
    <form
      onSubmit={(e) => {
        e.preventDefault();
        form.handleSubmit();
      }}
      className={cn("space-y-4", className)}
    >
      {children}
    </form>
  );
}
```

### 4. Layout Pattern

```typescript
type LayoutProps = BaseProps & {
  header?: React.ReactNode;
  footer?: React.ReactNode;
  sidebar?: React.ReactNode;
};

export function Layout({
  header,
  footer,
  sidebar,
  children,
  className,
}: LayoutProps) {
  return (
    <div className={cn("min-h-screen", className)}>
      {header && (
        <header className="sticky top-0 z-10 bg-background border-b">
          {header}
        </header>
      )}
      <div className="flex flex-1 min-h-0">
        {sidebar && (
          <aside className="w-64 border-e">
            {sidebar}
          </aside>
        )}
        <main className="flex-1 p-6">
          {children}
        </main>
      </div>
      {footer && (
        <footer className="border-t">
          {footer}
        </footer>
      )}
    </div>
  );
}
```

## Error Handling

### Error Boundary Pattern

```typescript
import { ErrorBoundary as ReactErrorBoundary, type FallbackProps } from 'react-error-boundary';

type ErrorBoundaryProps = {
  children: React.ReactNode;
  fallback?: React.ReactNode;
};

export function ErrorBoundary({ children, fallback }: ErrorBoundaryProps) {
  return (
    <ReactErrorBoundary
      FallbackComponent={fallback ? () => <>{fallback}</> : ErrorFallback}
      onReset={() => {
        queryClient.clear();
      }}
      onError={(error) => {
        logError(error);
      }}
    >
      {children}
    </ReactErrorBoundary>
  );
}

function ErrorFallback({ error, resetErrorBoundary }: FallbackProps) {
  return (
    <Card className="w-[420px] mx-auto mt-8">
      <CardHeader>
        <CardTitle>
          {error instanceof ApiError ? error.code : 'Application Error'}
        </CardTitle>
        <CardDescription>
          {error instanceof ApiError
            ? error.message
            : 'An unexpected error occurred'}
        </CardDescription>
      </CardHeader>
      <CardContent>
        {error instanceof ValidationError && (
          <ul className="list-disc pl-4 space-y-1">
            {Object.entries(error.fields).map(([field, message]) => (
              <li key={field} className="text-destructive">
                {message}
              </li>
            ))}
          </ul>
        )}
      </CardContent>
      <CardFooter>
        <Button
          variant="secondary"
          onClick={resetErrorBoundary}
          className="w-full"
        >
          Try Again
        </Button>
      </CardFooter>
    </Card>
  );
}
```

## Toast Patterns

```typescript
// Promise toast for async operations
function handleAsyncAction() {
  toast.promise(
    async () => {
      const result = await someAsyncOperation();
      return result;
    },
    {
      loading: 'Processing your request...',
      success: (data) => `Successfully processed ${data.name}`,
      error: (err) => err.message || 'An error occurred',
    }
  );
}

// Custom toast with action buttons
function handleDeletion(id: string) {
  toast('Are you sure you want to delete this?', {
    action: {
      label: 'Delete',
      onClick: () => deleteItem(id),
    },
    cancel: {
      label: 'Cancel',
      onClick: () => toast.dismiss(),
    },
  });
}

// Progress toast for file uploads
function handleFileUpload(file: File) {
  const toastId = toast('Uploading file...', {
    duration: Infinity,
    icon: <Loader2 className="size-4 animate-spin" />,
  });

  uploadFile(file, {
    onProgress: (progress) => {
      toast(
        <div className="w-full">
          <div className="mb-2">Uploading {file.name}</div>
          <div className="size-2 w-full bg-secondary rounded-full overflow-hidden">
            <div
              className="h-full bg-primary transition-all duration-300"
              style={{ width: `${progress}%` }}
            />
          </div>
        </div>,
        { id: toastId }
      );
    },
    onSuccess: () => {
      toast.success('File uploaded successfully', { id: toastId });
    },
    onError: (error) => {
      toast.error(`Upload failed: ${error.message}`, { id: toastId });
    },
  });
}
```

## Form Validation

```typescript
const userFormSchema = z.object({
  personal: z.object({
    name: z.string().min(2),
    email: z.string().email(),
  }),
  address: z.object({
    street: z.string(),
    city: z.string(),
  }),
});

function ComplexUserForm() {
  const form = createForm({
    defaultValues: {
      personal: { name: '', email: '' },
      address: { street: '', city: '' },
    },
    onSubmit: async ({ value }) => {
      try {
        await $createUser(value);
        toast.success('User created successfully');
        navigate({ to: '/users' });
      } catch (error) {
        toast.error(error instanceof Error ? error.message : "Failed to create user");
      }
    },
  });

  return (
    <Card>
      <CardHeader>
        <CardTitle>Create User</CardTitle>
        <CardDescription>Add a new user to the system</CardDescription>
      </CardHeader>
      <CardContent>
        <form
          onSubmit={(e) => {
            e.preventDefault();
            form.handleSubmit();
          }}
          className="space-y-6"
        >
          <div className="space-y-4">
            <h3 className="text-lg font-medium">Personal Information</h3>
            <Separator />
            <div className="space-y-4">
              <Field
                name="personal.name"
                children={(field) => (
                  <FormField
                    label="Name"
                    error={field.state.meta.touchedErrors?.[0]}
                    description="Enter your full name"
                  >
                    <Input
                      placeholder="Enter name"
                      value={field.state.value}
                      onBlur={field.handleBlur}
                      onChange={(e) => field.handleChange(e.target.value)}
                      className={cn(
                        field.state.meta.touchedErrors && "border-destructive"
                      )}
                    />
                  </FormField>
                )}
              />
              <Field
                name="personal.email"
                children={(field) => (
                  <FormField
                    label="Email"
                    error={field.state.meta.touchedErrors?.[0]}
                    description="We'll never share your email"
                  >
                    <Input
                      type="email"
                      placeholder="Enter email"
                      value={field.state.value}
                      onBlur={field.handleBlur}
                      onChange={(e) => field.handleChange(e.target.value)}
                      className={cn(
                        field.state.meta.touchedErrors && "border-destructive"
                      )}
                    />
                  </FormField>
                )}
              />
            </div>
          </div>
        </form>
      </CardContent>
      <CardFooter className="flex justify-end gap-2">
        <Button
          variant="outline"
          onClick={() => navigate({ to: '/users' })}
        >
          Cancel
        </Button>
        <Button
          type="submit"
          disabled={form.state.isSubmitting}
          onClick={() => form.handleSubmit()}
        >
          {form.state.isSubmitting ? (
            <>
              <Loader2 className="mr-2 h-4 w-4 animate-spin" />
              Creating...
            </>
          ) : (
            'Create User'
          )}
        </Button>
      </CardFooter>
    </Card>
  );
}
```
