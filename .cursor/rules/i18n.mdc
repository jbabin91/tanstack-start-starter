## Number and Date Formatting

### Format Utilities

```typescript
// app/lib/i18n/format.ts
export function formatNumber(
  value: number,
  options?: Intl.NumberFormatOptions,
): string {
  const { i18n } = useTranslation();
  return new Intl.NumberFormat(i18n.language, options).format(value);
}

export function formatCurrency(value: number, currency: string): string {
  return formatNumber(value, {
    style: 'currency',
    currency,
  });
}

export function formatDate(
  date: Date,
  options?: Intl.DateTimeFormatOptions,
): string {
  const { i18n } = useTranslation();
  return new Intl.DateTimeFormat(i18n.language, options).format(date);
}

// Usage with relative time
export function formatRelativeTime(date: Date): string {
  const { i18n } = useTranslation();
  const rtf = new Intl.RelativeTimeFormat(i18n.language, {
    numeric: 'auto',
  });

  const diff = date.getTime() - Date.now();
  const diffInDays = Math.round(diff / (1000 * 60 * 60 * 24));

  return rtf.format(diffInDays, 'day');
}
```

## Testing

### Translation Testing

```typescript
// tests/i18n/translations.test.ts
describe('Translations', () => {
  it('should have all required keys', () => {
    const baseTranslations = loadTranslationsSync('en');
    const otherLanguages = getAvailableLanguagesSync();

    for (const lang of otherLanguages) {
      if (lang === 'en') continue;

      const langTranslations = loadTranslationsSync(lang);
      const missingKeys = findMissingKeys(baseTranslations, langTranslations);

      expect(missingKeys).toHaveLength(0);
    }
  });

  it('should have valid interpolation variables', () => {
    const translations = loadTranslationsSync('en');
    const validation = validateTranslations(translations);

    expect(validation.isValid).toBe(true);
  });
});

// Component testing with translations
describe('LocalizedComponent', () => {
  it('should render with correct translation', () => {
    render(
      <I18nextProvider i18n={i18nForTests}>
        <LocalizedComponent />
      </I18nextProvider>,
    );

    expect(screen.getByText('Hello, World!')).toBeInTheDocument();
  });

  it('should handle RTL layout', () => {
    render(
      <I18nextProvider i18n={i18nForTests}>
        <RTLProvider>
          <LocalizedComponent />
        </RTLProvider>
      </I18nextProvider>,
    );

    const element = screen.getByTestId('rtl-element');
    expect(element).toHaveStyle({ direction: 'rtl' });
  });
});
```

## Best Practices

1. Translation Organization

   - Use nested namespaces
   - Keep translations close to features
   - Use consistent key naming
   - Document context for translators

2. RTL Support

   - Use logical properties
   - Test layouts in RTL
   - Handle text expansion
   - Consider cultural differences

3. Performance

   - Load translations on demand
   - Cache translations
   - Optimize bundle size
   - Handle loading states

4. Type Safety

   - Use TypeScript for translations
   - Validate translation files
   - Check for missing keys
   - Handle fallback languages

5. Testing
   - Test translations
   - Verify RTL layouts
   - Check formatting
   - Test loading states
