## Translation Structure

### Type Definitions

```typescript
// app/i18n/types.ts
type Translation = {
  common: {
    buttons: {
      submit: string;
      cancel: string;
    };
    errors: {
      required: string;
      invalid: string;
    };
  };
  features: {
    auth: {
      login: {
        title: string;
        description: string;
      };
    };
  };
};

// Ensure type safety
declare module 'react-i18next' {
  interface CustomTypeOptions {
    defaultNS: 'common';
    resources: {
      common: Translation['common'];
      features: Translation['features'];
    };
  }
}
```

