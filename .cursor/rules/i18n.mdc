## Translation Management

### Translation Workflow

```typescript
// scripts/i18n/manage-translations.ts
type TranslationStatus = {
  key: string;
  status: 'missing' | 'outdated' | 'ok';
  lastUpdated?: string;
};

export async function checkTranslationStatus(
  baseLanguage: string = 'en',
): Promise<Record<string, TranslationStatus[]>> {
  const baseTranslations = await loadTranslations(baseLanguage);
  const languages = await getAvailableLanguages();
  const status: Record<string, TranslationStatus[]> = {};

  for (const lang of languages) {
    if (lang === baseLanguage) continue;

    const langTranslations = await loadTranslations(lang);
    status[lang] = compareTranslations(baseTranslations, langTranslations);
  }

  return status;
}

// Translation validation
export function validateTranslations(
  translations: Record<string, unknown>,
): ValidationResult {
  const errors: ValidationError[] = [];

  // Check for missing interpolation variables
  const interpolationRegex = /{{\s*[\w.]+\s*}}/g;

  function checkNode(node: unknown, path: string[] = []) {
    if (typeof node === 'string') {
      const matches = node.match(interpolationRegex) || [];
      const uniqueVars = new Set(matches);

      if (uniqueVars.size > 0) {
        const key = path.join('.');
        errors.push({
          key,
          variables: Array.from(uniqueVars),
          type: 'interpolation',
        });
      }
    } else if (typeof node === 'object' && node !== null) {
      Object.entries(node).forEach(([key, value]) => {
        checkNode(value, [...path, key]);
      });
    }
  }

  checkNode(translations);

  return {
    isValid: errors.length === 0,
    errors,
  };
}
```

### Translation Components

```typescript
// app/components/i18n/language-switcher.tsx
export function LanguageSwitcher() {
  const { i18n } = useTranslation();
  const [isOpen, setIsOpen] = useState(false);

  return (
    <DropdownMenu open={isOpen} onOpenChange={setIsOpen}>
      <DropdownMenuTrigger asChild>
        <Button variant="ghost" className="flex items-center gap-2">
          <Globe className="h-4 w-4" />
          <span>{getLanguageName(i18n.language)}</span>
        </Button>
      </DropdownMenuTrigger>

      <DropdownMenuContent align="end">
        {supportedLanguages.map((lang) => (
          <DropdownMenuItem
            key={lang.code}
            onClick={() => {
              i18n.changeLanguage(lang.code);
              setIsOpen(false);
            }}
          >
            <span className="flex items-center gap-2">
              <span className={`fi fi-${lang.flag}`} />
              {lang.name}
            </span>
          </DropdownMenuItem>
        ))}
      </DropdownMenuContent>
    </DropdownMenu>
  );
}
