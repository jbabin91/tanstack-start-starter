## Security Architecture

### Authentication & Authorization

1. **Auth Middleware**:

```typescript
// lib/server/middleware/auth-guard.ts
import { createMiddleware } from '@tanstack/start';
import { getWebRequest, setResponseStatus } from '@tanstack/start/server';

export const authMiddleware = createMiddleware().server(async ({ next }) => {
  const { headers } = getWebRequest()!;

  const session = await auth.api.getSession({
    headers,
    query: {
      disableCookieCache: true, // Ensure fresh session
    },
  });

  if (!session) {
    setResponseStatus(401);
    throw new Error('Unauthorized');
  }

  return next({ context: { user: session.user } });
});
```

2. **Route Protection**:

```typescript
// routes/_app/route.tsx
export const Route = createFileRoute('/_app')({
  beforeLoad: [authGuard], // Protect all app routes
  component: AppLayout,
});
```

### Input Validation

1. **Server Function Validation**:

```typescript
// features/users/server/update-user.ts
import { createServerFn } from '@tanstack/start';
import { z } from 'zod';

const userSchema = z.object({
  id: z.string(),
  email: z.string().email(),
  name: z.string().min(2),
});

export const $updateUser = createServerFn({ method: 'POST' })
  .input(userSchema) // Validate input
  .handler(async ({ input }) => {
    return db.user.update({
      where: { id: input.id },
      data: input,
    });
  });
```

2. **API Route Validation**:

```typescript
// routes/api/email/send.ts
import { z } from 'zod';

const emailSchema = z.object({
  to: z.string().email(),
  template: z.string(),
  data: z.record(z.unknown()),
});

export const APIRoute = createAPIFileRoute('/api/email/send')({
  POST: async ({ request }) => {
    const body = await request.json();
    const { to, template, data } = emailSchema.parse(body);
    return resend.emails.send({ to, template, data });
  },
});
```

### CSRF Protection

1. **CSRF Token Validation**:

```typescript
// lib/server/middleware/csrf.ts
import { createMiddleware } from '@tanstack/start';

export const csrfMiddleware = createMiddleware().server(async ({ next }) => {
  const { headers } = getWebRequest()!;
  const token = headers.get('x-csrf-token');

  if (!token || !validateCsrfToken(token)) {
    setResponseStatus(403);
    throw new Error('Invalid CSRF token');
  }

  return next();
});
```

### Rate Limiting

1. **API Rate Limiting**:

```typescript
// lib/server/middleware/rate-limit.ts
import { createMiddleware } from '@tanstack/start';
import { Ratelimit } from '@upstash/ratelimit';
import { Redis } from '@upstash/redis';

const ratelimit = new Ratelimit({
  redis: Redis.fromEnv(),
  limiter: Ratelimit.slidingWindow(10, '10 s'),
});

export const rateLimitMiddleware = createMiddleware().server(
  async ({ next }) => {
    const { headers } = getWebRequest()!;
    const ip = headers.get('x-forwarded-for');

    const { success } = await ratelimit.limit(ip ?? 'anonymous');

    if (!success) {
      setResponseStatus(429);
      throw new Error('Too many requests');
    }

    return next();
  },
);
```

## Performance Optimizations

### Server Functions

1. **Caching Strategy**:

```typescript
// features/users/server/get-user.ts
import { createServerFn } from '@tanstack/start';

export const $getUser = createServerFn({ method: 'GET' })
  .input(z.object({ id: z.string() }))
  .handler(async ({ input }) => {
    // Use cache-control headers
    setResponseHeader('Cache-Control', 's-maxage=60');

    return db.user.findUnique({
      where: { id: input.id },
      // Select only needed fields
      select: {
        id: true,
        name: true,
        email: true,
      },
    });
  });
```

2. **Batch Operations**:

```typescript
// features/users/server/get-users.ts
export const $getUsers = createServerFn({ method: 'GET' })
  .input(z.object({ ids: z.array(z.string()) }))
  .handler(async ({ input }) => {
    // Batch fetch users
    return db.user.findMany({
      where: { id: { in: input.ids } },
    });
  });
```

### Asset Optimization

1. **Image Optimization**:

```typescript
// components/ui/image.tsx
