```

### Query Optimization

1. **Parallel Queries**:

```typescript
// features/dashboard/components/dashboard.tsx
function Dashboard() {
  // Fetch data in parallel
  const { data: user } = useUser();
  const { data: posts } = usePosts();
  const { data: stats } = useStats();

  return (/* ... */);
}
```

2. **Prefetching**:

```typescript
// features/posts/components/post-list.tsx
function PostList() {
  const { data: posts } = usePosts();
  const queryClient = useQueryClient();

  // Prefetch on hover
  const prefetchPost = (id: string) => {
    queryClient.prefetchQuery({
      queryKey: ['post', id],
      queryFn: () => $getPost({ id }),
    });
  };

  return (
    <ul>
      {posts.map((post) => (
        <li
          key={post.id}
          onMouseEnter={() => prefetchPost(post.id)}
        >
          {post.title}
        </li>
      ))}
    </ul>
  );
}
```

