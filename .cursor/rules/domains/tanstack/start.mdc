  },
});
```

2. **Static Asset Handling**:

```typescript
// app.config.ts
import { defineConfig } from '@tanstack/start/config';

export default defineConfig({
  vite: {
    build: {
      // Optimize chunks
      rollupOptions: {
        output: {
          manualChunks: {
            vendor: ['react', 'react-dom'],
          },
        },
      },
    },
  },
