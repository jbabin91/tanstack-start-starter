## Data Synchronization

### Real-time Updates

```typescript
// ✅ Good - Real-time data synchronization
function useRealtimeMessages() {
  const queryClient = useQueryClient();

  // Set up WebSocket connection
  useEffect(() => {
    const ws = new WebSocket('wss://api.example.com/messages');

    ws.onmessage = (event) => {
      const message = JSON.parse(event.data);
      // Update query cache with new message
      queryClient.setQueryData(['messages'], (old: Message[]) => [
        message,
        ...old,
      ]);
    };

    return () => ws.close();
  }, [queryClient]);

  // Regular query for initial data
  return useQuery({
    queryKey: ['messages'],
    queryFn: () => $getMessages(),
    // Keep real-time data fresh
    staleTime: Infinity,
  });
}
```

### Optimistic Updates

```typescript
// ✅ Good - Optimistic UI with proper error handling
function MessageList() {
  const mutation = useMutation({
    mutationFn: (message: string) => $sendMessage({ text: message }),
    // Optimistically add message
    onMutate: async (newMessage) => {
      await queryClient.cancelQueries({ queryKey: ['messages'] });
      const previousMessages = queryClient.getQueryData(['messages']);

      queryClient.setQueryData(['messages'], (old: Message[]) => [
        { id: 'temp', text: newMessage, pending: true },
        ...old,
      ]);

      return { previousMessages };
    },
    // Handle errors
    onError: (err, newMessage, context) => {
      queryClient.setQueryData(['messages'], context?.previousMessages);
      toast.error('Failed to send message');
    },
    // Update with server response
    onSuccess: (result) => {
      queryClient.setQueryData(['messages'], (old: Message[]) =>
        old.map((msg) =>
          msg.id === 'temp' ? { ...result, pending: false } : msg
        )
      );
    },
  });

  return (/* ... */);
}
```

