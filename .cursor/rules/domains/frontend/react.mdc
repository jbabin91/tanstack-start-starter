## Hooks Usage

### Built-in Hooks

1. useState:

```typescript
// ✅ Good - Proper state usage
function UserForm() {
  const [user, setUser] = useState<User | null>(null);

  // Use updater function for derived state
  const updateUser = (updates: Partial<User>) => {
    setUser(prev => prev ? { ...prev, ...updates } : null);
  };

  return (/* ... */);
}
```

2. useEffect:

```typescript
// ✅ Good - Proper effect usage
function UserProfile({ userId }: { userId: string }) {
  useEffect(() => {
    // Cleanup function
    const subscription = subscribe(userId);
    return () => subscription.unsubscribe();
  }, [userId]); // Clear dependencies

  // Separate effects for different concerns
  useEffect(() => {
    logProfileView(userId);
  }, [userId]);

  return (/* ... */);
}
```

3. useCallback:

```typescript
// ✅ Good - Proper callback usage
function UserList({ onUserSelect }: { onUserSelect: (user: User) => void }) {
  const handleUserClick = useCallback((user: User) => {
    analytics.track('user_selected', { userId: user.id });
    onUserSelect(user);
  }, [onUserSelect]);

  return (/* ... */);
}
```

### Custom Hooks

```typescript
// ✅ Good - Proper custom hook
function useUser(userId: string) {
  const [user, setUser] = useState<User | null>(null);
  const [error, setError] = useState<Error | null>(null);
  const [isLoading, setIsLoading] = useState(false);

  useEffect(() => {
    let isMounted = true;

    async function fetchUser() {
      setIsLoading(true);
      try {
        const data = await fetchUserData(userId);
        if (isMounted) {
          setUser(data);
          setError(null);
        }
      } catch (err) {
        if (isMounted) {
          setError(err as Error);
          setUser(null);
        }
      } finally {
        if (isMounted) {
          setIsLoading(false);
        }
      }
    }

    fetchUser();

    return () => {
      isMounted = false;
    };
  }, [userId]);

  return { user, error, isLoading };
}
```

## Performance Optimization

### React 19 Features

React 19 includes several automatic optimizations:

1. Automatic batching for all updates
2. Automatic memoization of components
3. Automatic code splitting with React.lazy
4. Automatic streaming with Suspense
5. Automatic error boundary recovery

```typescript
// ✅ Good - Let React 19 handle optimizations
function UserDashboard() {
  return (
    <Suspense fallback={<Loading />}>
      <UserProfile />
      <Suspense fallback={<ActivitySkeleton />}>
        <UserActivity />
      </Suspense>
    </Suspense>
  );
}
```

### Code Splitting

```typescript
// ✅ Good - Proper route splitting
// routes/dashboard/route.lazy.tsx
export const Route = createLazyFileRoute('/dashboard')({
  component: lazy(() => import('./DashboardPage')),
});

// Component-based splitting
const UserDashboard = lazy(() => import('./UserDashboard'));
const UserSettings = lazy(() => import('./UserSettings'));

function App() {
  return (
    <Suspense fallback={<Loading />}>
      <Routes>
        <Route path="/dashboard" element={<UserDashboard />} />
        <Route path="/settings" element={<UserSettings />} />
      </Routes>
    </Suspense>
  );
}
```

### Data Loading

```typescript
// ✅ Good - Parallel data loading
function Dashboard() {
