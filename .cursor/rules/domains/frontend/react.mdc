### Form State Management

```typescript
// ✅ Good - Form state management with React Hook Form
function ProfileForm() {
  const form = useForm<ProfileFormData>({
    mode: 'onChange', // Validate on change
    defaultValues: async () => {
      const profile = await fetchProfile();
      return {
        name: profile.name,
        email: profile.email,
      };
    },
  });

  const { isSubmitting, isDirty } = form.formState;

  return (
    <Form {...form}>
      <form onSubmit={form.handleSubmit(onSubmit)}>
        {/* Form fields */}
        <Button
          type="submit"
          disabled={!isDirty || isSubmitting}
        >
          {isSubmitting ? 'Saving...' : 'Save Changes'}
        </Button>
      </form>
    </Form>
  );
}
```

### Form Error Handling

```typescript
// ✅ Good - Form error handling
function SignupForm() {
  const form = useForm<SignupFormData>();
  const [serverError, setServerError] = useState<string | null>(null);

  const onSubmit = async (data: SignupFormData) => {
    try {
      await signup(data);
    } catch (error) {
      setServerError(error.message);
      // Set specific field errors if available
      if (error.field) {
        form.setError(error.field, {
          type: 'server',
          message: error.message,
        });
      }
    }
  };

  return (
    <Form {...form}>
      <form onSubmit={form.handleSubmit(onSubmit)}>
        {serverError && (
          <Alert variant="destructive">
            <AlertTitle>Error</AlertTitle>
            <AlertDescription>{serverError}</AlertDescription>
          </Alert>
        )}
        {/* Form fields */}
      </form>
    </Form>
  );
}
```

### Let the Compiler Work

React Compiler is designed to:

- Automatically track dependencies
- Optimize re-renders
- Handle function stability
- Manage referential equality
- Perform fine-grained updates

```typescript
// ✅ Good - Let React Compiler handle optimizations
function UserDashboard({ userId }: { userId: string }) {
  // Compiler handles all optimizations
  const formatName = (user: User) => {
    return `${user.firstName} ${user.lastName}`;
  };

  const handleUpdate = (data: UserData) => {
    updateUser(userId, data);
  };

  return (
    <div>
      <UserProfile
        userId={userId}
        formatName={formatName}
        onUpdate={handleUpdate}
      />
    </div>
  );
}
```
