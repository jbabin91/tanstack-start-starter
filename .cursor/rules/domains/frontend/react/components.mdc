# React Component Guidelines

## Overview

These guidelines establish best practices for creating and organizing React components in our TanStack Start application, focusing on component design, composition, and reusability.

## Guidelines

### Component Structure

1. **Function Components**:

```typescript
// ✅ Good - Proper component structure
interface UserProfileProps {
  userId: string;
  onUpdate?: (user: User) => void;
}

export function UserProfile({ userId, onUpdate }: UserProfileProps) {
  const { data: user } = useUser(userId);

  if (!user) {
    return <UserProfileSkeleton />;
  }

  return (
    <Card>
      <CardHeader>
        <CardTitle>{user.name}</CardTitle>
      </CardHeader>
      <CardContent>
        <UserDetails user={user} />
        {onUpdate && (
          <Button onClick={() => onUpdate(user)}>
            Update Profile
          </Button>
        )}
      </CardContent>
    </Card>
  );
}

// ❌ Bad - Poor component structure
export default function Profile(props: any) {
  const [userData, setUserData] = useState(null);

  useEffect(() => {
    fetch(`/api/users/${props.id}`).then(setUserData);
  }, [props.id]);

  if (!userData) return <div>Loading...</div>;

  return <div>{userData.name}</div>;
}
```

### Component Organization

```typescript
// features/users/components/UserProfile/index.tsx

// 1. Imports
import { type User } from '~/types';
import { useUser } from '~/features/users/hooks/useUser';
import { UserAvatar } from './UserAvatar';
import { UserDetails } from './UserDetails';
import { UserActions } from './UserActions';

// 2. Types
interface UserProfileProps {
  userId: string;
  onUpdate?: (user: User) => void;
}

// 3. Subcomponents
function UserHeader({ user }: { user: User }) {
  return (
    <div className="flex items-center gap-4">
      <UserAvatar user={user} />
      <h2 className="text-2xl font-bold">{user.name}</h2>
    </div>
  );
}

// 4. Main Component
export function UserProfile({ userId, onUpdate }: UserProfileProps) {
  const { data: user, isLoading, error } = useUser(userId);

  if (isLoading) {
    return <UserProfileSkeleton />;
  }

  if (error) {
    return <UserProfileError error={error} />;
  }

  return (
    <Card>
      <CardHeader>
        <UserHeader user={user} />
      </CardHeader>
      <CardContent>
        <UserDetails user={user} />
        <UserActions user={user} onUpdate={onUpdate} />
      </CardContent>
    </Card>
  );
}
```

### Component Composition

```typescript
// ✅ Good - Proper component composition
function DataTable<T>({ data, columns }: DataTableProps<T>) {
  return (
    <Table>
      <TableHeader>
        <TableRow>
          {columns.map((column) => (
            <TableHead key={column.id}>{column.header}</TableHead>
          ))}
        </TableRow>
      </TableHeader>
      <TableBody>
        {data.map((row) => (
          <TableRow key={row.id}>
            {columns.map((column) => (
              <TableCell key={column.id}>
                {column.cell(row)}
              </TableCell>
            ))}
          </TableRow>
        ))}
      </TableBody>
    </Table>
  );
}

// Usage
function UserTable() {
  const columns = [
    {
      id: 'name',
      header: 'Name',
      cell: (user: User) => <UserName user={user} />,
    },
    {
      id: 'email',
      header: 'Email',
      cell: (user: User) => <UserEmail user={user} />,
    },
  ];

  return <DataTable data={users} columns={columns} />;
}
```

### Error Boundaries

```typescript
// ✅ Good - Error boundary implementation
function ErrorBoundary({ children }: { children: React.ReactNode }) {
  return (
    <Suspense fallback={<Loading />}>
      <ErrorBoundaryImpl>
        {children}
      </ErrorBoundaryImpl>
    </Suspense>
  );
}

// Usage with routes
export const Route = createFileRoute('/dashboard')({
  component: DashboardPage,
  errorComponent: DashboardErrorBoundary,
});
```

### Component Loading States

```typescript
// ✅ Good - Proper loading states
function UserProfile({ userId }: { userId: string }) {
  const { data: user, isLoading, error } = useUser(userId);

  if (isLoading) {
    return (
      <Card>
        <CardHeader>
          <Skeleton className="h-8 w-48" />
        </CardHeader>
        <CardContent>
          <Skeleton className="h-32" />
        </CardContent>
      </Card>
    );
  }

  if (error) {
    return (
      <Alert variant="destructive">
        <AlertTitle>Error loading profile</AlertTitle>
        <AlertDescription>{error.message}</AlertDescription>
      </Alert>
    );
  }

  return <UserProfileContent user={user} />;
}
```

