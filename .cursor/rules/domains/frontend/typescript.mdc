## Type System

### Type Declarations

1. Use `type` over `interface`:

   ```typescript
   // ✅ Good - Using type for object shapes
   type User = {
     id: string;
     name: string;
     email: string;
   };

   // ✅ Good - Using type for component props
   type ButtonProps = {
     variant: 'primary' | 'secondary';
     onClick: () => void;
     children: React.ReactNode;
   };

   // ❌ Bad - Using interface
   interface User {
     id: string;
     name: string;
     email: string;
   }
   ```

   **Why `type` over `interface`?**

   - More consistent: `type` works for all use cases (unions, intersections, primitives)
   - Better error messages: `type` errors are typically more precise
   - No implicit merging: Prevents accidental interface augmentation
   - More flexible: Can use unions, mapped types, and utility types directly

   **Exception**: Only use `interface` when:

   - Declaring module augmentations
   - Working with declaration merging in `.d.ts` files

   ```typescript
   // ✅ Good - Module augmentation
   declare module '@tanstack/router' {
     interface Register {
       router: typeof router;
     }
   }
   ```

2. Type Inference:

   ```typescript
   // ✅ Good - Let TypeScript infer obvious types
   const users = ['Alice', 'Bob']; // string[]

   // ❌ Bad - Redundant type annotation
   const users: string[] = ['Alice', 'Bob'];
   ```

3. Generic Types:

   ```typescript
   // ✅ Good - Descriptive type parameters
   type Repository<TEntity> = {
     findById(id: string): Promise<TEntity>;
   };

   // ❌ Bad - Single-letter type parameters
   type Repository<T> = {
     findById(id: string): Promise<T>;
   };
   ```

4. Union Types:

   ```typescript
   // ✅ Good - Union types for finite options
   type Status = 'idle' | 'loading' | 'success' | 'error';
   type HttpMethod = 'GET' | 'POST' | 'PUT' | 'DELETE';

   // ❌ Bad - Using enums
   enum Status {
     Idle,
     Loading,
     Success,
     Error,
   }
   ```

5. Utility Types:

   ```typescript
   // ✅ Good - Using built-in utility types
   type UserUpdate = Partial<User>;
   type UserReadOnly = Readonly<User>;
   type UserKeys = keyof User;

   // ✅ Good - Custom utility types
   type NonNullableFields<T> = {
     [P in keyof T]: NonNullable<T[P]>;
   };
   ```

## React TypeScript

### Component Types

1. Function Components:

   ```typescript
   // ✅ Good - Using type for props
   type UserProfileProps = {
     id: string;
     onUpdate?: (user: User) => void;
   };

   function UserProfile({ id, onUpdate }: UserProfileProps) {
     // Implementation
   }

   // ❌ Bad - Using interface for props
   interface UserProfileProps {
     id: string;
     onUpdate?: (user: User) => void;
   }
   ```

2. Event Handlers:

   ```typescript
   // ✅ Good - Specific event types
   type ButtonProps = {
     onClick: (event: React.MouseEvent<HTMLButtonElement>) => void;
     onKeyPress: (event: React.KeyboardEvent<HTMLButtonElement>) => void;
   };

   // ❌ Bad - Using any or unknown
   type ButtonProps = {
     onClick: (event: any) => void;
   };
   ```

## State Management

### Type-Safe State

1. Zustand Store:

   ```typescript
   // ✅ Good - Type-safe store
   type AppState = {
     user: User | null;
     setUser: (user: User | null) => void;
   };

   const useStore = create<AppState>((set) => ({
     user: null,
     setUser: (user) => set({ user }),
   }));
   ```

2. React Query:

   ```typescript
   // ✅ Good - Typed queries
   function useUser(id: string) {
     return useQuery<User, Error>({
       queryKey: ['user', id],
       queryFn: () => fetchUser(id),
     });
   }
   ```

## API Integration

### Type-Safe API Calls

1. Request/Response Types:

   ```typescript
   type CreateUserRequest = {
     name: string;
     email: string;
   };

   type CreateUserResponse = {
     id: string;
     name: string;
     email: string;
     createdAt: string;
   };

   async function createUser(
     data: CreateUserRequest,
   ): Promise<CreateUserResponse> {
     const response = await fetch('/api/users', {
       method: 'POST',
       body: JSON.stringify(data),
     });
     return response.json();
   }
   ```

2. Error Types:

   ```typescript
   type ApiError = {
     code: string;
     message: string;
     details?: Record<string, unknown>;
   };

   async function fetchData<T>(url: string): Promise<T> {
     const response = await fetch(url);
     if (!response.ok) {
       const error: ApiError = await response.json();
       throw new Error(error.message);
     }
     return response.json();
   }
   ```

## Forms

### Form Types

#### Form Data Types

```typescript
// ✅ Good - Type-safe form data with Zod and React Hook Form
import { z } from 'zod';
import { useForm } from 'react-hook-form';
import { zodResolver } from '@hookform/resolvers/zod';

// Define schema with Zod
const loginSchema = z.object({
  email: z.string().email('Invalid email address'),
  password: z.string().min(8, 'Password must be at least 8 characters'),
  rememberMe: z.boolean().default(false),
});

// Infer types from schema
type LoginFormData = z.infer<typeof loginSchema>;

// Use inferred types with React Hook Form
function LoginForm() {
  const form = useForm<LoginFormData>({
    resolver: zodResolver(loginSchema),
    defaultValues: {
      email: '',
      password: '',
      rememberMe: false,
    },
  });

  // Form is now fully typed
  const onSubmit = (data: LoginFormData) => {
    // Type-safe access to form data
    const { email, password, rememberMe } = data;
  };
}
```

#### Form Component Types

```typescript
// ✅ Good - Type-safe form components with Shadcn UI
import { FormField } from '~/components/ui/form';
import type { ControllerRenderProps, FieldValues } from 'react-hook-form';

// Type-safe form field component
interface FormInputProps<T extends FieldValues> {
  name: keyof T;
  label: string;
  control: Control<T>;
  description?: string;
}

function FormInput<T extends FieldValues>({
  name,
  label,
  control,
  description,
}: FormInputProps<T>) {
  return (
    <FormField
      control={control}
      name={name}
      render={({ field }) => (
        <FormItem>
          <FormLabel>{label}</FormLabel>
          <FormControl>
            <Input {...field} />
          </FormControl>
          {description && (
            <FormDescription>{description}</FormDescription>
          )}
          <FormMessage />
        </FormItem>
      )}
    />
  );
}
```

#### Form Validation Types

```typescript
// ✅ Good - Type-safe form validation
import { z } from 'zod';

// Define reusable validation schemas
const emailSchema = z.string().email('Invalid email address');
const passwordSchema = z
  .string()
  .min(8, 'Password must be at least 8 characters');

// Compose schemas for different forms
const signupSchema = z
  .object({
    email: emailSchema,
    password: passwordSchema,
    confirmPassword: passwordSchema,
  })
  .refine((data) => data.password === data.confirmPassword, {
    message: "Passwords don't match",
    path: ['confirmPassword'],
  });

const profileSchema = z.object({
  email: emailSchema,
  name: z.string().min(2, 'Name must be at least 2 characters'),
  bio: z.string().max(500, 'Bio must be less than 500 characters').optional(),
});

// Type inference
type SignupFormData = z.infer<typeof signupSchema>;
type ProfileFormData = z.infer<typeof profileSchema>;
```

## Type Safety Best Practices

### Strict Mode

1. Enable Strict Mode:

   ```json
   {
     "compilerOptions": {
       "strict": true,
       "noImplicitAny": true,
       "strictNullChecks": true,
       "strictFunctionTypes": true,
       "strictBindCallApply": true,
       "strictPropertyInitialization": true,
       "noImplicitThis": true,
       "useUnknownInCatchVariables": true
     }
   }
   ```

### Type Guards

1. Custom Type Guards:

   ```typescript
   // ✅ Good - Type guard function
   function isUser(value: unknown): value is User {
     return (
       typeof value === 'object' &&
       value !== null &&
       'id' in value &&
       'name' in value
     );
   }

   // Usage
   if (isUser(data)) {
     console.log(data.name); // TypeScript knows data is User
   }
   ```

### Utility Types

1. Built-in Utility Types:

   ```typescript
   // ✅ Good - Using utility types
   type UserUpdate = Partial<User>;
   type UserReadOnly = Readonly<User>;
   type UserKeys = keyof User;
   type UserPick = Pick<User, 'id' | 'name'>;
   type UserOmit = Omit<User, 'password'>;
   ```
