    enableSorting: false,
    enableHiding: false,
  },
  {
    accessorKey: 'name',
    header: 'Name',
    cell: ({ row }) => <UserCell user={row.original} />,
  },
] satisfies ColumnDef<User>[];
```

## TanStack Virtual

### List Virtualization

```typescript
// ✅ Good - Proper virtual list
function VirtualUserList({ users }: { users: User[] }) {
  const parentRef = useRef(null);

  const rowVirtualizer = useVirtualizer({
    count: users.length,
    getScrollElement: () => parentRef.current,
    estimateSize: () => 50,
    overscan: 5,
  });

  return (
    <div
      ref={parentRef}
      className="h-[400px] overflow-auto"
    >
      <div
        style={{
          height: `${rowVirtualizer.getTotalSize()}px`,
          width: '100%',
          position: 'relative',
        }}
      >
        {rowVirtualizer.getVirtualItems().map((virtualRow) => (
          <div
            key={virtualRow.key}
            data-index={virtualRow.index}
            ref={rowVirtualizer.measureElement}
            style={{
              position: 'absolute',
              top: 0,
              left: 0,
              width: '100%',
              transform: `translateY(${virtualRow.start}px)`,
            }}
          >
            <UserListItem user={users[virtualRow.index]} />
          </div>
        ))}
      </div>
    </div>
  );
}
```

### Grid Virtualization

```typescript
// ✅ Good - Proper virtual grid
function VirtualGrid({ items }: { items: GridItem[] }) {
  const parentRef = useRef(null);

  const gridVirtualizer = useVirtualizer({
    count: items.length,
    getScrollElement: () => parentRef.current,
    estimateSize: () => 100,
    overscan: 5,
    horizontal: true,
    lanes: 3,
  });

  return (
    <div
      ref={parentRef}
      className="h-[400px] overflow-auto"
    >
      <div
        style={{
          height: `${gridVirtualizer.getTotalSize()}px`,
          width: '100%',
          position: 'relative',
        }}
      >
        {gridVirtualizer.getVirtualItems().map((virtualItem) => (
          <div
            key={virtualItem.key}
            data-index={virtualItem.index}
            style={{
              position: 'absolute',
              top: `${Math.floor(virtualItem.index / 3) * 100}px`,
              left: `${(virtualItem.index % 3) * 100}px`,
              width: '100px',
              height: '100px',
            }}
          >
            <GridItem item={items[virtualItem.index]} />
          </div>
        ))}
      </div>
    </div>
  );
}
```

## Best Practices

### Performance Optimization

1. Query Optimization:

   - Use proper stale time configuration
   - Implement optimistic updates
   - Configure proper cache invalidation
   - Use parallel queries when possible
   - Implement proper prefetching

2. Router Optimization:

   - Use proper code splitting
   - Implement proper data loading
   - Configure proper caching
   - Use proper prefetching
   - Handle loading states properly

3. Table Optimization:

   - Use proper virtualization for large datasets
   - Implement proper sorting/filtering
   - Configure proper pagination
   - Use proper row selection
   - Handle column management efficiently

4. Virtual List Optimization:
   - Use proper overscan configuration
   - Implement proper item measurement
   - Configure proper scroll restoration
   - Use proper dynamic sizing
   - Handle scroll sync efficiently

### Type Safety

1. Query Types:

   - Use proper type inference
   - Implement proper error types
   - Use proper validation
   - Handle loading states properly
   - Maintain proper type boundaries

2. Router Types:

   - Use proper route type inference
   - Implement proper context types
   - Use proper param validation
   - Handle search params properly
   - Maintain proper type safety

3. Table Types:

   - Use proper column definitions
   - Implement proper row types
   - Use proper state types
   - Handle selection types properly
   - Maintain proper type inference

4. Virtual Types:
   - Use proper item types
   - Implement proper measurement types
   - Use proper scroll types
   - Handle dynamic types properly
   - Maintain proper type safety

Remember: The goal is to leverage the full power of the TanStack Suite while maintaining type safety, performance, and maintainability.
