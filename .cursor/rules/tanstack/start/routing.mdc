# TanStack Start Routing Patterns

## Route Structure

### Directory Organization

```sh
routes/
├── __root.tsx           # Root layout with providers
├── _public/             # Public routes
│   ├── index.tsx       # Landing page
│   └── about.tsx       # About page
├── _auth/              # Authentication routes
│   ├── signin.tsx     # Sign in page
│   └── signup.tsx     # Sign up page
└── _app/              # Protected routes
    ├── route.tsx      # App layout with auth guard
    ├── dashboard/     # Dashboard feature
    │   ├── route.tsx  # Dashboard layout
    │   └── index.tsx  # Dashboard page
    └── settings/      # Settings feature
        ├── route.tsx  # Settings layout
        └── index.tsx  # Settings page
```

## Root Configuration

```typescript
// routes/__root.tsx
import { createRootRouteWithContext } from '@tanstack/react-router';
import type { RouterContext } from '~/lib/router';

export const Route = createRootRouteWithContext<RouterContext>()({
  beforeLoad: async () => {
    const user = await $getUser();
    return { user };
  },
  component: RootComponent,
  pendingComponent: RootSkeleton,
  errorComponent: RootError,
});

function RootComponent() {
  return (
    <div>
      <Providers>
        <Header />
        <main>
          <Outlet />
        </main>
        <Footer />
      </Providers>
    </div>
  );
}
```

## Route Types

### Public Routes

```typescript
// routes/_public/index.tsx
export const Route = createFileRoute('/_public/')({
  component: LandingPage,
});

// routes/_public/about.tsx
export const Route = createFileRoute('/_public/about')({
  component: AboutPage,
});
```

### Auth Routes

```typescript
// routes/_auth/route.tsx
export const Route = createFileRoute('/_auth')({
  beforeLoad: ({ context }) => {
    if (context.user) {
      throw redirect({ to: '/app' });
    }
  },
  component: AuthLayout,
});

// routes/_auth/signin.tsx
export const Route = createFileRoute('/_auth/signin')({
  component: SignInPage,
  validateSearch: z.object({
    redirect: z.string().optional(),
  }),
});
```

### Protected Routes

```typescript
// routes/_app/route.tsx
export const Route = createFileRoute('/_app')({
  beforeLoad: ({ context }) => {
    if (!context.user) {
      throw redirect({
        to: '/auth/signin',
        search: { redirect: window.location.pathname },
      });
    }
  },
  component: AppLayout,
  pendingComponent: AppSkeleton,
  errorComponent: AppError,
});
```

## Route Patterns

### Layout Routes

```typescript
// routes/_app/dashboard/route.tsx
export const Route = createFileRoute('/_app/dashboard')({
  component: DashboardLayout,
  loader: async () => {
    // Parallel data loading
    const [stats, activities] = await Promise.all([
      $fetchDashboardStats(),
      $fetchUserActivities(),
    ]);
    return { stats, activities };
  },
});

function DashboardLayout() {
  const { stats, activities } = useLoaderData();
  return (
    <div className="grid grid-cols-12 gap-4">
      <aside className="col-span-3">
        <DashboardSidebar stats={stats} />
      </aside>
      <main className="col-span-9">
        <Outlet />
      </main>
    </div>
  );
}
```

### Page Routes

```typescript
// routes/_app/dashboard/index.tsx
export const Route = createFileRoute('/_app/dashboard/')({
  component: DashboardPage,
  loader: async () => {
    return {
      recentActivity: await $fetchRecentActivity(),
    };
  },
});

function DashboardPage() {
  const { recentActivity } = useLoaderData();
  return (/* ... */);
}
```

### Dynamic Routes

```typescript
// routes/_app/users/[id].tsx
export const Route = createFileRoute('/_app/users/$id')({
  component: UserProfile,
  loader: async ({ params }) => {
    return {
      user: await $getUser({ id: params.id }),
    };
  },
  validateParams: z.object({
    id: z.string(),
  }),
});
```

## Route Guards

### Auth Guard

```typescript
// lib/guards/auth.tsx
export function createAuthGuard(to: string) {
  return ({ context }: { context: RouterContext }) => {
    if (!context.user) {
      throw redirect({
        to,
        search: { redirect: window.location.pathname },
      });
    }
  };
}

// routes/_app/settings/route.tsx
export const Route = createFileRoute('/_app/settings')({
  beforeLoad: createAuthGuard('/auth/signin'),
  component: SettingsLayout,
});
```

### Role Guard

```typescript
// lib/guards/role.tsx
export function createRoleGuard(roles: Role[]) {
  return ({ context }: { context: RouterContext }) => {
    if (!roles.includes(context.user?.role)) {
      throw new Error('Unauthorized');
    }
  };
}

// routes/_app/admin/route.tsx
export const Route = createFileRoute('/_app/admin')({
  beforeLoad: createRoleGuard(['ADMIN']),
  component: AdminLayout,
});
```

## Error Handling

### Error Components

```typescript
// components/errors/not-found.tsx
export function NotFound() {
  return (
    <div className="flex flex-col items-center justify-center min-h-screen">
      <h1>404: Page Not Found</h1>
      <p>The page you're looking for doesn't exist.</p>
      <Link to="/">Go Home</Link>
    </div>
  );
}

// components/errors/error-boundary.tsx
export function ErrorBoundary({ error }: { error: Error }) {
  return (
    <div role="alert" className="p-4 border border-red-500 rounded">
      <h2 className="text-red-500">Something went wrong</h2>
      <pre className="mt-2 text-sm">{error.message}</pre>
    </div>
  );
}
```

## Search Params

### Validation

```typescript
// routes/_app/users/index.tsx
export const Route = createFileRoute('/_app/users/')({
  validateSearch: z.object({
    page: z.number().default(1),
    limit: z.number().default(10),
    search: z.string().optional(),
    sort: z.enum(['name', 'email', 'createdAt']).optional(),
    order: z.enum(['asc', 'desc']).optional(),
  }),
  loader: async ({ search }) => {
    return {
      users: await $getUsers(search),
    };
  },
  component: UsersPage,
});
```

### Usage

```typescript
function UsersPage() {
  const { users } = useLoaderData();
  const { search, setSearch } = useSearch();

  return (
    <div>
      <SearchInput
        value={search.search}
        onChange={(value) => setSearch({ search: value })}
      />
      <DataTable
        data={users}
        pageIndex={search.page - 1}
        pageSize={search.limit}
        onPaginationChange={({ pageIndex, pageSize }) => {
          setSearch({
            page: pageIndex + 1,
            limit: pageSize,
          });
        }}
      />
    </div>
  );
}
```

