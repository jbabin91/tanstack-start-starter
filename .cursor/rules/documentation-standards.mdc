 * @throws {ApiError} When the API request fails
 * @example
 * const user = await fetchUser('123');
 */
async function fetchUser(userId: string): Promise<User> {
  // Implementation
}

/**
 * User component displays user information
 * @param {UserProps} props - The component props
 * @returns {JSX.Element} The rendered component
 */
function UserComponent({ user, onUpdate }: UserProps): JSX.Element {
  // Implementation
}
```

### API Documentation

```typescript
/**
 * @api {get} /users/:id Get User
 * @apiName GetUser
 * @apiGroup Users
 * @apiVersion 1.0.0
 *
 * @apiParam {String} id User's unique ID
 *
 * @apiSuccess {Object} user User's data
 * @apiSuccess {String} user.id User's unique ID
 * @apiSuccess {String} user.name User's name
 * @apiSuccess {String} user.email User's email
 *
 * @apiError {Object} error Error response
 * @apiError {String} error.message Error message
 */
```

### Project Documentation

```markdown
# Project Name

## Overview

Brief project description

## Getting Started

1. Installation steps
2. Configuration
3. Running locally

## Architecture

- Component structure
- Data flow
- External dependencies

## Contributing

- Setup guide
- Coding standards
- Pull request process
```

## Best Practices

### 1. Code Documentation

- Use JSDoc for TypeScript/JavaScript
- Document public APIs
- Include examples
- Explain complex logic
- Keep comments up-to-date

### 2. Project Documentation

- Clear README structure
- Installation guides
- Architecture overview
- Contributing guidelines
- Troubleshooting guide
- Use relative paths for cross-references (e.g., `./file.mdc` for same directory, `../dir/file.mdc` for parent directory)

### 3. Documentation Maintenance

- Regular updates
- Version control
- Review process
- Automated checks
- Team feedback

### 4. Documentation Tools

- TypeDoc for API docs
- MDX for component docs
- Storybook for UI docs
- Swagger for REST APIs
- Markdown for guides

