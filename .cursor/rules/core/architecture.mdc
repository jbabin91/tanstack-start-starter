### API Organization Example

```typescript
// features/users/api/profile.ts

// Types can be imported from types.ts
import type { GetProfileParams, Profile, UpdateProfileData } from './types';

// Server functions
export const $getProfile = createServerFn<GetProfileParams, Profile>(
  'getProfile',
  async ({ id }) => {
    // Server-side code
    return profile;
  },
);

// Client hooks
export const useProfile = (id: string) => {
  return useQuery({
    queryKey: ['profile', id],
    queryFn: () => $getProfile({ id }),
  });
};

export const useUpdateProfile = () => {
  return useMutation({
    mutationFn: (data: UpdateProfileData) => $updateProfile(data),
  });
};
```

Benefits:

- Explicit file naming (no index files)
- Clear file purposes
- Easy to locate files
- Consistent naming patterns
- Better IDE support
- Simpler imports

