### Error Handling Example

```typescript
// lib/errors/types.ts
export type ApiError = {
  code: string;
  message: string;
  details?: Record<string, unknown>;
};

// constants/api.ts
export const API_ERROR_CODES = {
  NOT_FOUND: 'NOT_FOUND',
  UNAUTHORIZED: 'UNAUTHORIZED',
  VALIDATION_ERROR: 'VALIDATION_ERROR',
} as const;

// lib/errors/handlers.ts
import { API_ERROR_CODES } from '~/constants/api';
import type { ApiError } from './types';

export const handleApiError = (error: ApiError) => {
  switch (error.code) {
    case API_ERROR_CODES.NOT_FOUND:
      // Handle not found
      break;
    case API_ERROR_CODES.UNAUTHORIZED:
      // Handle unauthorized
      break;
    default:
      // Handle unknown error
  }
};

// features/users/errors/types.ts
import { API_ERROR_CODES } from '~/constants/api';
import type { ApiError } from '~/lib/errors/types';

export type UserApiError = ApiError & {
  code: typeof API_ERROR_CODES.NOT_FOUND | typeof API_ERROR_CODES.UNAUTHORIZED;
};

// features/users/errors/handlers.ts
import { handleApiError } from '~/lib/errors/handlers';
import type { UserApiError } from './types';

export const handleUserError = (error: UserApiError) => {
  // Feature-specific error handling
  handleApiError(error);
};

// components/errors/ApiError.tsx
import { API_ERROR_CODES } from '~/constants/api';
import type { ApiError } from '~/lib/errors/types';

export function ApiError({ error }: { error: ApiError }) {
  switch (error.code) {
    case API_ERROR_CODES.NOT_FOUND:
      return <NotFoundError message={error.message} />;
    case API_ERROR_CODES.UNAUTHORIZED:
      return <UnauthorizedError message={error.message} />;
    default:
      return <GenericError message={error.message} />;
  }
}

// features/users/api/profile.ts
import { API_ERROR_CODES } from '~/constants/api';
import { handleUserError } from '../errors/handlers';
import type { UserApiError } from '../errors/types';

export const $getProfile = createServerFn<GetProfileParams, Profile, UserApiError>(
  'getProfile',
  async ({ id }) => {
    try {
      // Server-side code
      if (!user) {
        throw {
          code: API_ERROR_CODES.NOT_FOUND,
          message: 'User not found'
        };
      }
      return user;
    } catch (error) {
      handleUserError(error as UserApiError);
      throw error;
    }
  },
);
```

