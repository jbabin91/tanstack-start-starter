### Validation Organization Example

```typescript
// features/users/validation/schemas.ts
import { z } from 'zod';

export const userSchema = z.object({
  email: z.string().email(),
  password: z.string().min(8),
  name: z.string().min(2),
});

// features/users/validation/rules.ts
import type { User } from '../types';

export const validatePassword = (password: string): boolean => {
  // Custom password validation logic
  return (
    password.length >= 8 &&
    /[A-Z]/.test(password) &&
    /[a-z]/.test(password) &&
    /[0-9]/.test(password)
  );
};

export const validateUserProfile = (user: Partial<User>): string[] => {
  const errors: string[] = [];

  if (user.name && user.name.length < 2) {
    errors.push('Name must be at least 2 characters');
  }

  if (user.password && !validatePassword(user.password)) {
    errors.push('Password must meet complexity requirements');
  }

  return errors;
};

// features/users/api/profile.ts
import { userSchema } from '../validation/schemas';
import { validateUserProfile } from '../validation/rules';

export const $updateProfile = createServerFn<UpdateProfileData, Profile>(
  'updateProfile',
  async (data) => {
    // Zod schema validation
    const result = userSchema.safeParse(data);
    if (!result.success) {
      throw new ValidationError(result.error);
    }

    // Custom validation rules
    const errors = validateUserProfile(data);
    if (errors.length > 0) {
      throw new ValidationError(errors);
    }

    // Proceed with update
    return updateUser(data);
  },
);
```

Benefits of this validation structure:

- Clear separation of validation logic
- Type-safe validation
- Consistent validation rules
- Feature-specific validation
- Centralized validation logic
- Easy to add new validations
- Consistent error handling

