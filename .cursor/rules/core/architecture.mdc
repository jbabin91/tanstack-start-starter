### i18n Organization Example

```typescript
// i18n/types.ts
export type CommonTranslations = {
  errors: {
    notFound: string;
    unauthorized: string;
  };
  actions: {
    save: string;
    cancel: string;
    delete: string;
  };
};

export type UserTranslations = {
  profile: {
    title: string;
    editButton: string;
    deleteAccount: string;
  };
  settings: {
    title: string;
    language: string;
    theme: string;
  };
};

// i18n/locales/en/common.json
{
  "errors": {
    "notFound": "Not found",
    "unauthorized": "Unauthorized"
  },
  "actions": {
    "save": "Save",
    "cancel": "Cancel",
    "delete": "Delete"
  }
}

// i18n/locales/en/features/users.json
{
  "profile": {
    "title": "Profile",
    "editButton": "Edit Profile",
    "deleteAccount": "Delete Account"
  },
  "settings": {
    "title": "Settings",
    "language": "Language",
    "theme": "Theme"
  }
}

// i18n/config.ts
import { createI18nServer } from '@tanstack/react-i18n';
import type { CommonTranslations, UserTranslations } from './types';

export const i18n = createI18nServer({
  defaultLocale: 'en',
  locales: ['en', 'es'],
  namespaces: ['common', 'users'],
  resources: {
    en: {
      common: () => import('./locales/en/common.json'),
      users: () => import('./locales/en/features/users.json'),
    },
    es: {
      common: () => import('./locales/es/common.json'),
      users: () => import('./locales/es/features/users.json'),
    },
  },
});

// Example usage in a component
import { useTranslation } from '@tanstack/react-i18n';

export function ProfilePage() {
  const { t } = useTranslation();

  return (
    <div>
      <h1>{t('users.profile.title')}</h1>
      <button>{t('users.profile.editButton')}</button>
      <button className="text-red-500">
        {t('users.profile.deleteAccount')}
      </button>
    </div>
  );
}
```

Benefits of this i18n structure:

- Clear separation of translations by language and feature
- Type-safe translations with TypeScript
- Lazy loading of translation files
- Easy to add new languages
- Maintainable organization
- Feature-specific translations
- Common shared translations

