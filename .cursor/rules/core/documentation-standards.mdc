## Code Documentation

### File Headers

```typescript
/**
 * @file Component for displaying user profile information
 * @module features/user/components
 */
```

### Component Documentation {#component-documentation}

````typescript
/**
 * Component Documentation Pattern
 *
 * 1. Description: Clear, concise description of the component
 * 2. Props: Document each prop with type and purpose
 * 3. Example: Show typical usage
 * 4. Return: What the component renders
 * 5. Notes: Any important implementation details
 */

/**
 * Displays user profile information with edit capabilities
 *
 * @description
 * A form-based component that allows viewing and editing user profile data.
 * Handles loading, error, and success states.
 *
 * @example
 * ```tsx
 * <UserProfile
 *   user={user}
 *   onUpdate={handleUpdate}
 *   isReadOnly={false}
 * />
 * ```
 *
 * @param props - Component props
 * @param props.user - User data to display
 * @param props.onUpdate - Callback when user data is updated
 * @param props.isReadOnly - Optional flag to disable editing
 *
 * @returns A form with user profile fields and edit controls
 */
export function UserProfile({
  user,
  onUpdate,
  isReadOnly = false,
}: UserProfileProps) {
  // Implementation
}
````

### Function Documentation

```typescript
/**
 * Fetches user data from the API
 * @param {string} userId - The unique identifier of the user
 * @returns {Promise<User>} The user data
 * @throws {ApiError} When the API request fails
 * @example
 * const user = await fetchUser('123');
 */
async function fetchUser(userId: string): Promise<User> {
  // Implementation
}
```

### Type Documentation

```typescript
/**
 * Represents a user in the system
 * @property id - Unique identifier
 * @property name - User's full name
 * @property email - User's email address
 */
type User = {
  id: string;
  name: string;
  email: string;
};
```

### API Documentation

```typescript
/**
 * @api {get} /users/:id Get User
 * @apiName GetUser
 * @apiGroup Users
 * @apiVersion 1.0.0
 *
 * @apiParam {String} id User's unique ID
 *
 * @apiSuccess {Object} user User's data
 * @apiSuccess {String} user.id User's unique ID
 * @apiSuccess {String} user.name User's name
 * @apiSuccess {String} user.email User's email
 *
 * @apiError {Object} error Error response
 * @apiError {String} error.message Error message
 */
```

