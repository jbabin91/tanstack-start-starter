### Scripts

```typescript
// scripts/i18n/validate.ts
import { validateTranslations } from '@/lib/i18n/utils';
import { readFileSync, readdirSync } from 'fs';
import { join } from 'path';
import { commonSchema, authSchema } from '@/lib/i18n/schemas';

const LOCALES_DIR = 'public/locales';
const schemaMap = {
  'common.json': commonSchema,
  'auth.json': authSchema,
};

export function validateTranslations() {
  const locales = readdirSync(LOCALES_DIR);

  for (const locale of locales) {
    const files = readdirSync(join(LOCALES_DIR, locale));

    for (const file of files) {
      if (file.endsWith('.json')) {
        const content = JSON.parse(
          readFileSync(join(LOCALES_DIR, locale, file),
          'utf-8',
        );
        const schema = schemaMap[file];
        if (schema) {
          try {
            schema.parse(content);
          } catch (error) {
            console.error(`Invalid translations in ${locale}/${file}:`, error);
          }
        }
      }
    }
  }
}

// Run validation
validateTranslations();
```

