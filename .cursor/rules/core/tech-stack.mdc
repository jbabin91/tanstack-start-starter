### Form Security with React Hook Form

```typescript
// ✅ Proper form security
function SecureForm() {
  const form = useForm<FormValues>({
    resolver: zodResolver(formSchema),
  });

  const onSubmit = async (values: FormValues) => {
    try {
      // Get CSRF token
      const csrfToken = await getCsrfToken();

      const response = await fetch('/api/submit', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken,
        },
        credentials: 'include',
        body: JSON.stringify(values),
      });

      if (!response.ok) {
        throw new Error('Submission failed');
      }
    } catch (error) {
      // Handle error
    }
  };

  return (
    <Form {...form}>
      <form
        onSubmit={form.handleSubmit(onSubmit)}
        autoComplete="off"
      >
        <FormField
          control={form.control}
          name="password"
          render={({ field }) => (
            <FormItem>
              <FormLabel>Password</FormLabel>
              <FormControl>
                <Input
                  {...field}
                  type="password"
                  autoComplete="new-password"
                  // Prevent password logging
                  onInput={(e) => {
                    e.currentTarget.setAttribute(
                      'value',
                      '*'.repeat(e.currentTarget.value.length)
                    );
                  }}
                />
              </FormControl>
            </FormItem>
          )}
        />
      </form>
    </Form>
  );
}

// ❌ Poor security
function UnsecureForm() {
  const onSubmit = (data) => {
    // Don't submit without CSRF protection
    fetch('/api/submit', {
      method: 'POST',
      body: JSON.stringify(data),
    });
  };

  return (
    <form onSubmit={handleSubmit(onSubmit)}>
      <input
        type="password"
        // Don't log sensitive data
        onChange={(e) => console.log('Password:', e.target.value)}
      />
    </form>
  );
}
```

