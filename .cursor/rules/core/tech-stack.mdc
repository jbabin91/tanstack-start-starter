### Form Performance

```typescript
// ✅ Proper form performance
function PerformantForm() {
  const form = useForm<FormValues>({
    mode: 'onBlur', // Validate on blur instead of onChange
    defaultValues: {
      email: '',
      password: '',
    },
  });

  // Memoize callback
  const onSubmit = useCallback(async (values: FormValues) => {
    await submitForm(values);
  }, []);

  // Memoize expensive computations
  const isValid = useMemo(() => {
    return Object.keys(form.formState.errors).length === 0;
  }, [form.formState.errors]);

  return (
    <Form {...form}>
      <form onSubmit={form.handleSubmit(onSubmit)}>
        {/* Form fields */}
      </form>
    </Form>
  );
}

// ❌ Poor performance
function UnperformantForm() {
  const form = useForm<FormValues>({
    mode: 'onChange', // Don't validate on every change
  });

  // Don't create new functions on every render
  const onSubmit = async (values: FormValues) => {
    await submitForm(values);
  };

  // Don't compute on every render
  const isValid = Object.keys(form.formState.errors).length === 0;
}
```

