// app/lib/i18n/utils.ts
import { type Resources } from './types';

export function validateTranslations(
  resources: Resources,
  schemas: Record<string, z.ZodSchema>,
) {
  Object.entries(resources).forEach(([lang, namespaces]) => {
    Object.entries(namespaces).forEach(([ns, translations]) => {
      const schema = schemas[ns];
      if (schema) {
        try {
          schema.parse(translations);
        } catch (error) {
          console.error(`Invalid translations in ${lang}/${ns}:`, error);
        }
      }
    });
  });
}
```

