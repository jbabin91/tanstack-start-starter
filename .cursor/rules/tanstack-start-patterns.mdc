## Query Optimization Patterns

```typescript
// ✅ Proper query optimization with React 19
function UserDashboard() {
  // Parallel queries with Suspense
  return (
    <Suspense fallback={<SkeletonLoader />}>
      <ErrorBoundary>
        <UserProfile />
        <Suspense fallback={<ActivitySkeleton />}>
          <UserActivity />
        </Suspense>
      </ErrorBoundary>
    </Suspense>
  );
}

// Proper query component
function UserProfile() {
  const query = useQuery({
    queryKey: ['user-profile'],
    queryFn: fetchUserProfile,
    staleTime: 5 * 60 * 1000, // 5 minutes
    gcTime: 30 * 60 * 1000,   // 30 minutes
  });

  // React 19 handles errors automatically
  return <ProfileCard user={query.data} />;
}

// Proper mutation with optimistic updates
function useUpdateProfile() {
  const queryClient = useQueryClient();

  return useMutation({
    mutationFn: updateProfile,
    onMutate: async (newProfile) => {
      await queryClient.cancelQueries({
        queryKey: ['user-profile']
      });

      const previousProfile = queryClient.getQueryData(['user-profile']);
      queryClient.setQueryData(['user-profile'], newProfile);

      return { previousProfile };
    },
    onError: (err, newProfile, context) => {
      queryClient.setQueryData(
        ['user-profile'],
        context?.previousProfile
      );
    },
    onSettled: () => {
      queryClient.invalidateQueries({
        queryKey: ['user-profile']
      });
    },
  });
}

// ❌ Poor query optimization
function UserDashboard() {
  // Don't fetch queries sequentially
  const { data: user } = useQuery(['user'], fetchUser);
  const { data: stats } = useQuery(['stats'], fetchStats);
  const { data: settings } = useQuery(
    ['settings', user?.id],
    () => fetchSettings(user?.id)
  );

  // Don't handle loading states manually
  if (!user || !stats || !settings) {
    return <LoadingSpinner />;
  }

  // Don't handle errors manually
  if (error) {
    return <ErrorMessage error={error} />;
  }
}
```

## Router Optimization Patterns

```typescript
// ✅ Proper router optimization with TanStack Start
// app/routes/__root.tsx
export const Route = createRootRouteWithContext<RouterContext>()({
  // Proper data loading with server function
  beforeLoad: async () => {
    const user = await $getUser();
    return { user };
  },
  component: RootComponent,
  // Proper meta configuration
  head: () => ({
    links: [
      { href: appCss, rel: 'stylesheet' },
      { href: '/favicon.ico', rel: 'icon' },
    ],
    meta: [
      { charSet: 'utf8' },
      { content: 'width=device-width, initial-scale=1', name: 'viewport' },
      ...seo({
        title: 'TanStack Start',
        description: 'Type-Safe, Full-Stack React Framework',
      }),
    ],
  }),
});

// app/routes/dashboard/route.tsx
export const Route = createFileRoute('/dashboard')({
  // Proper auth guard
  beforeLoad: ({ context }) => {
    if (!context.user) {
      throw redirect({ to: '/signin' });
    }
  },
  component: DashboardLayout,
});

// app/routes/dashboard/index.tsx
export const Route = createFileRoute('/dashboard/')({
  component: DashboardPage,
  // Proper parallel data loading
  loader: async () => {
    const [stats, activities] = await Promise.all([
      $fetchDashboardStats(),
      $fetchUserActivities(),
    ]);
    return { stats, activities };
  },
});

// app/routes/_auth/signin.tsx
export const Route = createFileRoute('/_auth/signin')({
  component: SignInPage,
  // Proper redirect for authenticated users
  beforeLoad: ({ context }) => {
    if (context.user) {
      throw redirect({ to: '/dashboard' });
    }
  },
});

// ❌ Poor router optimization
// Don't mix layout and page logic in one file
export const Route = createFileRoute('/dashboard')({
  component: ({ children }) => (
    <Layout>
      <PageContent /> {/* Page logic should be in index.tsx */}
      {children}
    </Layout>
  ),
});

// Don't fetch data sequentially
export const Route = createFileRoute('/dashboard/')({
  loader: async () => {
    const stats = await $fetchDashboardStats();
    const activities = await $fetchUserActivities(); // Should be parallel
    return { stats, activities };
  },
});

// Don't handle auth in page components
function DashboardPage() {
  const { user } = useAuth();
  if (!user) return <Navigate to="/signin" />; // Should be in route.tsx
  return <Dashboard />;
}
```

