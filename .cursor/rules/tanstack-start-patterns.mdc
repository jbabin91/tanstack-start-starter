## Form Optimization Patterns

```typescript
// ✅ Proper form optimization
function UserForm() {
  const form = useForm({
    // Proper default values
    defaultValues: {
      name: '',
      email: '',
    },
    // Proper validation mode
    mode: 'onBlur',
    // Proper resolver
    resolver: zodResolver(userSchema),
  });

  // Proper mutation handling
  const mutation = useMutation({
    mutationFn: updateUser,
    // Optimistic updates
    onMutate: async (newUser) => {
      await queryClient.cancelQueries(['user']);
      const previousUser = queryClient.getQueryData(['user']);
      queryClient.setQueryData(['user'], newUser);
      return { previousUser };
    },
    // Proper error handling
    onError: (err, newUser, context) => {
      queryClient.setQueryData(['user'], context.previousUser);
    },
    // Proper success handling
    onSuccess: () => {
      queryClient.invalidateQueries(['user']);
    },
  });

  return (
    <form onSubmit={form.handleSubmit(data => mutation.mutate(data))}>
      {/* Field Arrays for better performance */}
      <FieldArray
        name="addresses"
        render={({ fields }) => (
          <VirtualizedList
            items={fields}
            renderItem={(field) => (
              <AddressField key={field.id} field={field} />
            )}
          />
        )}
      />
    </form>
  );
}

// ❌ Poor form optimization
function UserForm() {
  // Don't use uncontrolled form
  const [formData, setFormData] = useState({});
  // Don't validate on every change
  const [errors, setErrors] = useState({});

  // Don't render all fields without virtualization
  return (
    <form>
      {addresses.map(address => (
        <AddressField key={address.id} address={address} />
      ))}
    </form>
  );
}
```

## Virtual List Optimization

```typescript
// ✅ Proper virtual list optimization
function UserList() {
  const { data: users } = useQuery({
    queryKey: ['users'],
    queryFn: fetchUsers,
  });

  return (
    <VirtualList
      items={users}
      // Proper overscan for smooth scrolling
      overscan={5}
      // Proper item size estimation
      estimateSize={(index) => {
        const item = users[index];
        return item.type === 'header' ? 48 : 32;
      }}
      // Proper render optimization
      renderItem={useCallback(({ index, style }) => (
        <div style={style}>
          <UserItem user={users[index]} />
        </div>
      ), [users])}
    />
  );
}

// ❌ Poor list optimization
function UserList() {
  const { data: users } = useQuery(['users'], fetchUsers);
  // Don't render all items at once
  return users?.map(user => <UserItem user={user} />);
}
```

