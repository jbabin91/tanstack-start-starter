### Translation Usage

```typescript
// ✅ Proper translation usage
function UserProfile() {
  // Load multiple namespaces at component level
  const { t, i18n } = useTranslation(['profile', 'common']);

  // Basic translation with namespace
  const title = t('profile:title');

  // Variables and interpolation
  const welcome = t('profile:welcome', { name: user.name });

  // Pluralization
  const postsCount = t('profile:posts', { count: user.posts.length });

  // Complex translations with Trans component
  return (
    <div>
      <h1>{title}</h1>
      <p>{welcome}</p>
      <p>{postsCount}</p>

      {/* Complex translations with HTML */}
      <Trans i18nKey="profile:description">
        This profile has <strong>{{ count: posts.length }}</strong> posts
        and was last updated on <time>{{ date }}</time>
      </Trans>

      {/* Nested translations */}
      <Trans i18nKey="profile:links">
        Visit our <a href="/terms">terms</a> and <a href="/privacy">privacy policy</a>
      </Trans>

      {/* Error handling */}
      {error && (
        <p role="alert">
          {t('common:errors.generic')}
        </p>
      )}
    </div>
  );
}

// ❌ Poor translation usage
function UserProfile() {
  // Don't create translation hook conditionally
  if (user) {
    const { t } = useTranslation();
    return <div>{t('Welcome') + user.name}</div>; // Don't concatenate
  }

  // Don't use multiple t() calls for the same concept
  return (
    <div>
      {t('Welcome')} {t('to')} {t('profile')}
    </div>
  );
}
```

