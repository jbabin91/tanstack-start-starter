### State Management Optimization

```typescript
// ✅ Proper state optimization
function UserSettings() {
  // Compiler will optimize state updates
  const [settings, setSettings] = useState({
    theme: 'light',
    notifications: true,
  });

  // Compiler will optimize this update
  const toggleTheme = () => {
    setSettings(prev => ({
      ...prev,
      theme: prev.theme === 'light' ? 'dark' : 'light',
    }));
  };

  // Compiler will optimize this derived state
  const isDarkMode = settings.theme === 'dark';

  return (
    <div data-theme={settings.theme}>
      <button onClick={toggleTheme}>
        Toggle {isDarkMode ? 'Light' : 'Dark'} Mode
      </button>
    </div>
  );
}

// ❌ Poor state optimization
function UserSettings() {
  // Don't split related state
  const [theme, setTheme] = useState('light');
  const [isDark, setIsDark] = useState(false);

  // Don't update multiple states for the same change
  const toggleTheme = () => {
    setTheme(prev => prev === 'light' ? 'dark' : 'light');
    setIsDark(prev => !prev);
  };
}
