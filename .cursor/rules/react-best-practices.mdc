// ✅ Proper i18n implementation
import { useTranslation, Trans } from 'react-i18next';

function LocalizedComponent() {
  const { t, i18n } = useTranslation(['common', 'forms']);

  // Proper language switching
  const toggleLanguage = async () => {
    const newLang = i18n.language === 'en' ? 'es' : 'en';
    await i18n.changeLanguage(newLang);
    document.documentElement.lang = newLang;
    document.documentElement.dir = i18n.dir(newLang);
  };

  return (
    <div>
      {/* Basic translation */}
      <h1>{t('forms:title')}</h1>

      {/* Pluralization */}
      <p>
        {t('common:items', {
          count: items.length,
          defaultValue_zero: 'No items',
          defaultValue_one: 'One item',
          defaultValue_other: '{{count}} items',
        })}
      </p>

      {/* Complex translations */}
      <Trans
        i18nKey="forms:terms"
        components={{
          bold: <strong />,
          link: <a href="/terms" />,
        }}
        values={{
          company: 'Acme Inc',
        }}
      >
        By signing up, you agree to <bold>{{company}}</bold>'s
        <link>Terms of Service</link>
      </Trans>

      {/* Number formatting */}
      <p>
        {t('common:price', {
          price: new Intl.NumberFormat(i18n.language, {
            style: 'currency',
            currency: 'USD',
          }).format(price),
        })}
      </p>

      {/* Date formatting */}
      <p>
        {t('common:lastUpdated', {
          date: new Intl.DateTimeFormat(i18n.language, {
            dateStyle: 'long',
            timeStyle: 'short',
          }).format(date),
        })}
      </p>

      {/* Language switcher */}
      <button
        onClick={toggleLanguage}
        aria-label={t('common:switchLanguage')}
      >
        {t('common:language')}
      </button>
    </div>
  );
}

// ❌ Poor i18n implementation
