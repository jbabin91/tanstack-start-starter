### Translation Loading

```typescript
// ✅ Proper translation loading
function App() {
  const { i18n } = useTranslation();
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => {
    // Load namespaces and language
    Promise.all([
      i18n.loadNamespaces(['common', 'profile']),
      i18n.changeLanguage(userPreferredLanguage)
    ]).then(() => {
      setIsLoading(false);
    });
  }, [i18n]);

  if (isLoading) {
    return <Suspense fallback={<LoadingSpinner />} />;
  }

  return <MainContent />;
}

// ❌ Poor translation loading
function App() {
  const { t } = useTranslation();

  // Don't change language without handling loading
  useEffect(() => {
    i18n.changeLanguage(userPreferredLanguage);
  }, []);

  // Don't access translations before loading
  return <div>{t('loading')}</div>;
}
```

### Translation Error Handling

```typescript
// ✅ Proper translation error handling
function TranslatedContent() {
  const { t, i18n } = useTranslation();
  const [error, setError] = useState<Error | null>(null);

  useEffect(() => {
    i18n.loadNamespaces(['common', 'profile'])
      .catch((err) => {
        setError(err);
        console.error('Failed to load translations:', err);
      });
  }, [i18n]);

  if (error) {
    return (
      <div role="alert">
        {t('common:errors.loadingFailed', 'Failed to load translations')}
      </div>
    );
  }

  return <MainContent />;
}

// ❌ Poor translation error handling
