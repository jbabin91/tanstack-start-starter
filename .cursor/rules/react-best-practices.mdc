## Accessibility and Internationalization

### Accessibility Guidelines

```typescript
// ✅ Proper accessibility implementation with React 19
function AccessibleForm() {
  const [isSubmitting, setIsSubmitting] = useState(false);
  const formRef = useRef<HTMLFormElement>(null);
  const errorRef = useRef<HTMLDivElement>(null);

  // Proper focus management
  useEffect(() => {
    if (formRef.current) {
      const firstInput = formRef.current.querySelector('input, select, textarea');
      if (firstInput instanceof HTMLElement) {
        firstInput.focus();
      }
    }
  }, []);

  // Proper error focus
  useEffect(() => {
    if (error && errorRef.current) {
      errorRef.current.focus();
    }
  }, [error]);

  return (
    <form
      ref={formRef}
      onSubmit={handleSubmit}
      aria-busy={isSubmitting}
      noValidate
    >
      {/* Proper form structure */}
      <div role="group" aria-labelledby="personal-info">
        <h2 id="personal-info">Personal Information</h2>

        {/* Proper label association */}
        <div>
          <label htmlFor="name">
            Full Name
            <span aria-hidden="true">*</span>
            <span className="sr-only">(Required)</span>
          </label>
          <input
            id="name"
            type="text"
            required
            aria-required="true"
            aria-invalid={!!errors.name}
            aria-describedby={errors.name ? "name-error" : undefined}
          />
          {errors.name && (
            <div
              id="name-error"
              role="alert"
              className="text-red-500"
            >
              {errors.name}
            </div>
          )}
        </div>

        {/* Proper ARIA live regions */}
        <div
          aria-live="polite"
          aria-atomic="true"
          className="sr-only"
        >
          {isSubmitting ? "Submitting form..." : ""}
        </div>

        {/* Proper button states */}
        <button
          type="submit"
          disabled={isSubmitting}
          aria-busy={isSubmitting}
        >
          {isSubmitting ? "Submitting..." : "Submit"}
        </button>
      </div>

      {/* Proper error summary */}
      {error && (
        <div
          ref={errorRef}
          role="alert"
          tabIndex={-1}
          className="border-red-500 p-4"
        >
          <h2>Error Submitting Form</h2>
          <p>{error.message}</p>
        </div>
      )}
    </form>
  );
}

// ❌ Poor accessibility
function InaccessibleForm() {
  return (
    <div>
      <div>Name *</div>
      <input />
      <div className="text-red-500">Error message</div>
      <button>Submit</button>
    </div>
  );
}
```

