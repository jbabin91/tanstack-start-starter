## Server Functions

### Basic Patterns

```typescript
// Basic server function
const $getUser = createServerFn()
  .input(z.object({ id: z.string().uuid() }))
  .query(async ({ input }) => {
    const user = await db.query.users.findFirst({
      where: eq(users.id, input.id),
    });
    if (!user) throw new NotFoundError('User not found');
    return user;
  });

// Paginated server function
const $getUsers = createServerFn()
  .input(
    z.object({
      page: z.number().min(1).default(1),
      sort: z.enum(['asc', 'desc']).default('desc'),
    }),
  )
  .query(async ({ input }) => {
    const { page, sort } = input;
    const limit = 10;
    const offset = (page - 1) * limit;

    const [items, total] = await Promise.all([
      db.query.users.findMany({
        limit,
        offset,
        orderBy: [desc(users.createdAt)],
      }),
      db.query.users.count(),
    ]);

    return {
      items,
      total,
      page,
      pageSize: limit,
      hasMore: offset + items.length < total,
    };
  });

// Mutation server function
const $createUser = createServerFn()
  .input(
    z.object({
      name: z.string().min(2),
      email: z.string().email(),
    }),
  )
  .mutation(async ({ input }) => {
    try {
      const user = await db.insert(users).values(input);
      return user;
    } catch (error) {
      if (error instanceof UniqueConstraintError) {
        throw new ValidationError('Email already exists');
      }
      throw error;
    }
  });
```

### Query Patterns

```typescript
// Query options factory
export const userQueryOptions = (id: string) => {
  return queryOptions({
    queryKey: ['user', id],
    queryFn: () => $getUser({ id }),
  });
};

// Paginated query options
export const usersQueryOptions = ({ page = 1, sort = 'desc' as const }) => {
  return queryOptions({
    queryKey: ['users', { page, sort }],
    queryFn: () => $getUsers({ page, sort }),
  });
};

// Infinite query pattern
export const useInfinitePostsQuery = () => {
  return useInfiniteQuery({
    queryKey: ['posts', 'infinite'],
    queryFn: ({ pageParam = 0 }) => $getPosts({ page: pageParam }),
    getNextPageParam: (lastPage) => lastPage.nextCursor,
  });
};
```

### Mutation Patterns

```typescript
// Basic mutation
export const useCreateUserMutation = () => {
  return useMutation({
    mutationFn: (data: CreateUserData) => $createUser(data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['users'] });
    },
  });
};

// Optimistic update mutation
export const useUpdateUserMutation = () => {
  return useMutation({
    mutationFn: (data: UpdateUserData) => $updateUser(data),
    onMutate: async (newUser) => {
      await queryClient.cancelQueries({ queryKey: ['user', newUser.id] });
      const previousUser = queryClient.getQueryData(['user', newUser.id]);
      queryClient.setQueryData(['user', newUser.id], newUser);
      return { previousUser };
    },
    onError: (err, newUser, context) => {
      queryClient.setQueryData(['user', newUser.id], context.previousUser);
    },
    onSettled: (data, error, variables) => {
      queryClient.invalidateQueries({ queryKey: ['user', variables.id] });
    },
  });
};
```

## Error Handling

### Error Types

```typescript
// Base error type
class ApiError extends Error {
  constructor(
    message: string,
    public code: string,
    public status: number = 400,
  ) {
    super(message);
    this.name = 'ApiError';
  }
}

// Validation error
class ValidationError extends ApiError {
  constructor(
    message: string,
    public fields?: Record<string, string>,
  ) {
    super(message, 'VALIDATION_ERROR', 400);
    this.name = 'ValidationError';
  }
}

// Not found error
class NotFoundError extends ApiError {
  constructor(message: string) {
    super(message, 'NOT_FOUND', 404);
    this.name = 'NotFoundError';
  }
}

// Auth error
class AuthError extends ApiError {
  constructor(
    message: string,
    public redirect?: string,
  ) {
    super(message, 'AUTH_ERROR', 401);
    this.name = 'AuthError';
  }
}
```

### Error Logging

```typescript
// Error logging middleware
export const errorLogger = async (
  error: unknown,
  { route, params }: { route: string; params: Record<string, unknown> },
) => {
  if (error instanceof ApiError) {
    // Log expected errors with context
    console.error({
      type: error.name,
      code: error.code,
      message: error.message,
      route,
      params,
    });
    return;
  }

  // Log unexpected errors with stack
  console.error({
    type: 'UnexpectedError',
    error,
    route,
    params,
    stack: error instanceof Error ? error.stack : undefined,
  });
};
```

### Error Retry

```typescript
// Error boundary with retry logic
export const withRetry = (fn: () => Promise<any>, maxRetries = 3) => {
  let attempts = 0;
  const attempt = async (): Promise<any> => {
    try {
      return await fn();
    } catch (error) {
      attempts++;
      if (attempts === maxRetries) throw error;
      await new Promise((resolve) => setTimeout(resolve, 1000 * attempts));
      return attempt();
    }
  };
  return attempt();
};
```

## Response Types

```typescript
// Pagination response type
type PaginatedResponse<T> = {
  items: T[];
  total: number;
  page: number;
  pageSize: number;
  hasMore: boolean;
};

// API response type
type ApiResponse<T> = {
  data: T;
  error?: {
    code: string;
    message: string;
    fields?: Record<string, string>;
  };
};

// Zod schemas
const userSchema = z.object({
  email: z.string().email(),
  name: z.string().min(2),
  role: z.enum(['user', 'admin']),
  preferences: z
    .object({
      theme: z.enum(['light', 'dark']).default('light'),
      notifications: z.boolean().default(true),
    })
    .optional(),
});

// Partial schema for updates
const userUpdateSchema = userSchema.partial();

// Array schema with refinements
const batchUsersSchema = z
  .array(userSchema)
  .min(1)
  .max(100)
  .refine((users) => new Set(users.map((u) => u.email)).size === users.length, {
    message: 'Duplicate emails are not allowed',
  });
```

## Authentication

### Auth Setup

```typescript
// app/lib/server/auth.ts
import { createAuth } from '@better-auth/core';

export const auth = createAuth({
  providers: ['discord', 'github', 'google'],
  session: {
    strategy: 'jwt',
  },
  pages: {
    signIn: '/login',
  },
});

// Export auth utilities
export const { getSession, requireSession } = auth;
```

### Session Handling

```typescript
// Protected route
export const Route = createFileRoute('/protected')({
  beforeLoad: async () => {
    await requireSession();
  },
});

// Logout handling
export const Route = createFileRoute('/logout')({
  loader: async () => {
    await auth.signOut();
    return redirect('/');
  },
});
```

### OAuth Handling

```typescript
export const Route = createFileRoute('/auth/callback/:provider')({
  loader: async ({ params }) => {
    const { provider } = params;
    try {
      await handleOAuthCallback(provider);
      return redirect('/dashboard');
    } catch (error) {
      return redirect('/login?error=oauth_failed');
    }
  },
});
```

## Best Practices

1. Server Functions

   - Always validate inputs
   - Handle errors consistently
   - Return typed responses
   - Use proper error types

2. Queries

   - Use consistent key structure
   - Handle loading states
   - Implement error boundaries
   - Cache appropriately

3. Mutations

   - Validate before sending
   - Handle optimistic updates
   - Show loading states
   - Provide feedback

4. Error Handling

   - Use proper error types
   - Log errors appropriately
   - Implement retries
   - Show user feedback

5. Authentication
   - Protect routes properly
   - Handle session expiry
   - Implement refresh flow
   - Secure sensitive data

