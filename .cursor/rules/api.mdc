```typescript
// Error logging middleware
export const errorLogger = async (
  error: unknown,
  { route, params }: { route: string; params: Record<string, unknown> },
) => {
  if (error instanceof ApiError) {
    // Log expected errors with context
    console.error({
      type: error.name,
      code: error.code,
      message: error.message,
      route,
      params,
    });
    return;
  }

  // Log unexpected errors with stack
  console.error({
    type: 'UnexpectedError',
    error,
    route,
    params,
    stack: error instanceof Error ? error.stack : undefined,
  });
};
```

```typescript
// Error boundary with retry logic
export const withRetry = (fn: () => Promise<any>, maxRetries = 3) => {
  let attempts = 0;
  const attempt = async (): Promise<any> => {
    try {
      return await fn();
    } catch (error) {
      attempts++;
      if (attempts === maxRetries) throw error;
      await new Promise((resolve) => setTimeout(resolve, 1000 * attempts));
      return attempt();
    }
  };
  return attempt();
};
```
