### Component Documentation

````typescript
/**
 * Displays user profile information with editable fields
 *
 * @example
 * ```tsx
 * <UserProfile
 *   user={user}
 *   onUpdate={handleUpdate}
 *   isEditable={true}
 * />
 * ```
 */
interface UserProfileProps {
  /** The user data to display */
  user: User;
  /** Called when user data is updated */
  onUpdate: (user: User) => Promise<void>;
  /** Whether the profile is editable */
  isEditable?: boolean;
}
````

### Type Documentation

```typescript
/**
 * Represents a user in the system
 * @see UserProfile for display component
 * @see UserForm for edit component
 */
interface User {
  /** Unique identifier */
  id: string;
  /** User's full name */
  name: string;
  /** User's email address */
  email: string;
  /** User's role in the system */
  role: UserRole;
  /** When the user was created */
  createdAt: Date;
}
```

