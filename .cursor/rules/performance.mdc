## Image Optimization

### Image Guidelines

```typescript
// app/lib/utils/image-optimization.ts
export const imageOptimizationRules = {
  formats: ['webp', 'avif'],
  sizes: {
    thumbnail: { width: 150, height: 150 },
    preview: { width: 300, height: 300 },
    full: { width: 1200, height: 800 },
  },
  quality: {
    webp: 80,
    avif: 70,
    jpeg: 85,
  },
};

// Image component with optimization
export function OptimizedImage({
  src,
  alt,
  size = 'full',
}: OptimizedImageProps) {
  return (
    <img
      src={src}
      alt={alt}
      width={imageOptimizationRules.sizes[size].width}
      height={imageOptimizationRules.sizes[size].height}
      loading="lazy"
      decoding="async"
      {...generateSrcSet(src)}
    />
  );
}
```

## Code Splitting

### Route-based Splitting

```typescript
// app/routes/_index.tsx
import { lazy } from 'react';
import { createFileRoute } from '@tanstack/react-router';

const HeavyComponent = lazy(() => import('~/components/heavy-component'));

export const Route = createFileRoute('/')({
  component: () => (
    <Suspense fallback={<LoadingSkeleton />}>
      <HeavyComponent />
    </Suspense>
  ),
});
```

### Component-based Splitting

```typescript
// app/components/data-grid/index.tsx
export const DataGrid = lazy(() =>
  import('./data-grid-component').then((module) => ({
    default: module.DataGrid,
  })),
);
```

## Caching Strategy

### HTTP Cache Headers

```typescript
// app/lib/server/cache-control.ts
export const cacheControl = {
  static: 'public, max-age=31536000, immutable',
  dynamic: 'public, max-age=3600, stale-while-revalidate=86400',
  api: 'private, no-cache, no-store, must-revalidate',
};

// Usage in server function
export const $getData = createServerFn()
  .input(z.object({ id: z.string() }))
  .handler(async ({ input }) => {
    // Set cache headers
    setHeader('Cache-Control', cacheControl.dynamic);
    // ... implementation
  });
```

### Query Caching

```typescript
// app/lib/query/cache-config.ts
export const queryConfig = {
  defaultOptions: {
    queries: {
      staleTime: 1000 * 60 * 5, // 5 minutes
      gcTime: 1000 * 60 * 60, // 1 hour
      retry: 3,
    },
  },
};

// Usage in route
export const Route = createFileRoute('/data')({
  loader: ({ context: { queryClient } }) =>
    queryClient.ensureQueryData(
      queryOptions({
        queryKey: ['data'],
        queryFn: () => $getData(),
        staleTime: 1000 * 60 * 5, // 5 minutes
      }),
    ),
});
```

