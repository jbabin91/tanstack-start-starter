## Input Validation

### Request Validation

```typescript
// app/lib/validation/request.ts
export const validateRequest = <T>(schema: z.ZodType<T>) => {
  return async (req: Request): Promise<ValidationResult<T>> => {
    try {
      const data = await req.json();
      const validated = await schema.parseAsync(data);
      return { success: true, data: validated };
    } catch (error) {
      if (error instanceof z.ZodError) {
        return {
          success: false,
          error: {
            code: 'VALIDATION_ERROR',
            message: 'Invalid request data',
            details: error.errors,
          },
        };
      }
      throw error;
    }
  };
};
```

### Content Security

```typescript
// app/lib/security/content.ts
export const sanitizeHtml = (dirty: string): string => {
  return DOMPurify.sanitize(dirty, {
    ALLOWED_TAGS: ['b', 'i', 'em', 'strong', 'a'],
    ALLOWED_ATTR: ['href', 'title', 'target'],
    ALLOW_DATA_ATTR: false,
    ADD_ATTR: ['target="_blank"'],
    FORBID_TAGS: ['style', 'script'],
    FORBID_ATTR: ['style', 'onerror', 'onload'],
  });
};

export const validateFileUpload = async (
  file: File,
): Promise<ValidationResult> => {
  const validTypes = ['image/jpeg', 'image/png', 'image/webp'];
  const maxSize = 5 * 1024 * 1024; // 5MB

  if (!validTypes.includes(file.type)) {
    return {
      success: false,
      error: 'Invalid file type',
    };
  }

  if (file.size > maxSize) {
    return {
      success: false,
      error: 'File too large',
    };
  }

  // Additional checks (magic numbers, etc.)
  const header = await readFileHeader(file);
  if (!isValidImageHeader(header)) {
    return {
      success: false,
      error: 'Invalid file content',
    };
  }

  return { success: true };
};
```

## Rate Limiting

### API Rate Limiting

```typescript
// app/lib/security/rate-limit.ts
export const createRateLimiter = (options: {
  windowMs: number;
  max: number;
  keyGenerator?: (req: Request) => string;
}) => {
  const limiter = new Map<string, number[]>();

  return async (req: Request): Promise<RateLimitResult> => {
    const key = options.keyGenerator?.(req) ?? req.ip;
    const now = Date.now();

    // Clean old requests
    limiter.set(
      key,
      (limiter.get(key) ?? []).filter(
        (timestamp) => now - timestamp < options.windowMs,
      ),
    );

    const requests = limiter.get(key) ?? [];

    if (requests.length >= options.max) {
      return {
        allowed: false,
        resetTime: requests[0] + options.windowMs,
      };
    }

    requests.push(now);
    limiter.set(key, requests);

    return { allowed: true };
  };
};

export const apiRateLimiter = createRateLimiter({
  windowMs: 15 * 60 * 1000, // 15 minutes
  max: 100, // limit each IP to 100 requests per windowMs
});
```

## Encryption

### Data Encryption

```typescript
// app/lib/security/encryption.ts
import { createCipheriv, createDecipheriv, randomBytes } from 'crypto';

export const encryption = {
  algorithm: 'aes-256-gcm',
  keyLength: 32,
  ivLength: 16,
  tagLength: 16,
};

export async function encrypt(
  data: string,
  key: Buffer,
): Promise<EncryptedData> {
  const iv = randomBytes(encryption.ivLength);
  const cipher = createCipheriv(encryption.algorithm, key, iv);

  const encrypted = Buffer.concat([
    cipher.update(data, 'utf8'),
    cipher.final(),
  ]);

  const tag = cipher.getAuthTag();

  return {
    encrypted: encrypted.toString('base64'),
    iv: iv.toString('base64'),
    tag: tag.toString('base64'),
  };
}

export async function decrypt(
  encryptedData: EncryptedData,
  key: Buffer,
): Promise<string> {
  const decipher = createDecipheriv(
    encryption.algorithm,
    key,
    Buffer.from(encryptedData.iv, 'base64'),
  );

  decipher.setAuthTag(Buffer.from(encryptedData.tag, 'base64'));

  const decrypted = Buffer.concat([
    decipher.update(Buffer.from(encryptedData.encrypted, 'base64')),
    decipher.final(),
  ]);

  return decrypted.toString('utf8');
}
```

