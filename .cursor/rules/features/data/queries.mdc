## Implementation

### 1. Query Client Setup

```typescript
import { QueryClient } from '@tanstack/react-query';

export const queryClient = new QueryClient({
  defaultOptions: {
    queries: {
      staleTime: 1000 * 60 * 5, // 5 minutes
      cacheTime: 1000 * 60 * 30, // 30 minutes
      retry: 3,
      retryDelay: (attemptIndex) => Math.min(1000 * 2 ** attemptIndex, 30000),
      refetchOnWindowFocus: true,
      refetchOnReconnect: true,
    },
  },
});
```

### 2. Basic Queries

```typescript
import { useQuery } from '@tanstack/react-query';
import { db } from '~/db';
import { users, posts } from '~/db/schema';
import { eq } from 'drizzle-orm';

type User = {
  id: number;
  email: string;
  name: string;
  createdAt: Date;
  updatedAt: Date;
};

type Post = {
  id: number;
  title: string;
  content: string;
  published: boolean;
  authorId: number;
  createdAt: Date;
  updatedAt: Date;
};

type PaginatedResponse<T> = {
  data: T[];
  pagination: {
    total: number;
    pages: number;
    current: number;
  };
};

type InfiniteResponse<T> = {
  data: T[];
  nextCursor?: number;
};

// User query hook
export function useUser(id: number) {
  return useQuery({
    queryKey: ['user', id],
    queryFn: async () => {
      const [user] = await db.select().from(users).where(eq(users.id, id));

      if (!user) {
        throw new Error('User not found');
      }

      return user;
    },
  });
}

// Posts query hook
export function usePosts(userId: number) {
  return useQuery({
    queryKey: ['posts', userId],
    queryFn: async () => {
      return db.select().from(posts).where(eq(posts.authorId, userId));
    },
  });
}
```

### 3. Dependent Queries

```typescript
// User posts query
export function useUserPosts(userId: string | undefined) {
  return useQuery({
    queryKey: ['posts', userId],
    queryFn: () => getPosts(userId!),
    enabled: !!userId,
    select: (posts) => posts.sort((a, b) => b.date - a.date),
  });
}

// User with posts
export function useUserWithPosts(userId: string) {
  const userQuery = useUser(userId);
  const postsQuery = useUserPosts(userId);

  return {
    user: userQuery.data,
    posts: postsQuery.data,
    isLoading: userQuery.isLoading || postsQuery.isLoading,
    error: userQuery.error || postsQuery.error,
  };
}
```

### 4. Infinite Queries

```typescript
// Infinite posts query
export function useInfinitePosts() {
  return useInfiniteQuery({
    queryKey: ['posts', 'infinite'],
    queryFn: ({ pageParam = 1 }) => getPosts({ page: pageParam }),
    getNextPageParam: (lastPage) => lastPage.nextPage,
    select: (data) => ({
      posts: data.pages.flatMap((page) => page.items),
      hasMore: data.pages[data.pages.length - 1].hasMore,
    }),
  });
}
```

### 5. Prefetching

```typescript
// Prefetch configuration
export async function prefetchInitialData() {
  await Promise.all([
    queryClient.prefetchQuery({
      queryKey: ['user'],
      queryFn: getCurrentUser,
    }),
    queryClient.prefetchQuery({
      queryKey: ['settings'],
      queryFn: getSettings,
    }),
  ]);
}

// Prefetch on hover
export function usePrefetchUser() {
  const queryClient = useQueryClient();

  return (userId: string) => {
    queryClient.prefetchQuery({
      queryKey: ['user', userId],
      queryFn: () => getUser(userId),
    });
  };
}
```

### 6. Suspense Mode

```typescript
// Suspense-enabled query
export function UserProfile({ userId }: { userId: string }) {
  return (
    <Suspense fallback={<Skeleton />}>
      <UserData userId={userId} />
    </Suspense>
  );
}

function UserData({ userId }: { userId: string }) {
  const { data: user } = useUser(userId);
  const { data: posts } = useUserPosts(userId);

  return (
    <div>
      <UserInfo user={user} />
      <UserPosts posts={posts} />
    </div>
  );
}
```

## Best Practices

### 1. Query Keys

- Use array keys for better organization
- Include all dependencies
- Keep keys consistent
- Document key structure
- Handle dynamic keys

### 2. Cache Management

- Set appropriate stale time
- Configure cache time
- Handle cache invalidation
- Implement prefetching
- Manage cache updates

### 3. Error Handling

- Implement retry logic
- Handle network errors
- Show error states
- Provide fallbacks
- Log errors properly

### 4. Performance

- Use suspense mode
- Implement prefetching
- Configure polling
- Handle background updates
- Monitor query performance

