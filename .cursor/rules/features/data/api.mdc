### Data Fetching Components

```typescript
import { useQuery } from '@tanstack/react-query';
import { LoadingSpinner, ErrorCard, EmptyState } from '~/components/ui/feedback';
import { z } from 'zod';

// Validation schema for API response
const ApiResponseSchema = z.object({
  data: z.unknown(),
  error: z.object({
    message: z.string(),
    code: z.string().optional(),
  }).optional(),
});

interface DataFetchProps<TData> {
  queryKey: string[];
  queryFn: () => Promise<TData>;
  LoadingComponent?: React.ComponentType;
  ErrorComponent?: React.ComponentType<{ error: Error; retry: () => void }>;
  EmptyComponent?: React.ComponentType;
  children: (data: TData) => React.ReactNode;
}

export function DataFetch<TData>({
  queryKey,
  queryFn,
  LoadingComponent = DefaultLoading,
  ErrorComponent = DefaultError,
  EmptyComponent = DefaultEmpty,
  children,
}: DataFetchProps<TData>) {
  const {
    data,
    error,
    isLoading,
    isError,
    refetch,
  } = useQuery({
    queryKey,
    queryFn: async () => {
      const response = await queryFn();
      const result = ApiResponseSchema.safeParse(response);

      if (!result.success) {
        throw new Error('Invalid API response format');
      }

      if (result.data.error) {
        throw new Error(result.data.error.message);
      }

      return result.data.data as TData;
    },
  });

  if (isLoading) {
    return <LoadingComponent />;
  }

  if (isError && error instanceof Error) {
    return <ErrorComponent error={error} retry={() => refetch()} />;
  }

  if (!data) {
    return <EmptyComponent />;
  }

  return children(data);
}

// Default components
function DefaultLoading() {
  return (
    <div className="flex justify-center p-4">
      <LoadingSpinner />
    </div>
  );
}

function DefaultError({ error, retry }: { error: Error; retry: () => void }) {
  return (
    <ErrorCard
      error={{ message: error.message }}
      onRetry={retry}
      className="mx-auto max-w-md"
    />
  );
}

function DefaultEmpty() {
  return (
    <EmptyState
      icon={InboxIcon}
      title="No data available"
      description="There is no data to display at this time."
      className="mx-auto max-w-md"
    />
  );
}

// Example usage with custom error boundaries
interface QueryBoundaryProps {
  children: React.ReactNode;
  fallback?: React.ReactNode;
}

export class QueryBoundary extends React.Component<
  QueryBoundaryProps,
  { hasError: boolean }
> {
  constructor(props: QueryBoundaryProps) {
    super(props);
    this.state = { hasError: false };
  }

  static getDerivedStateFromError() {
    return { hasError: true };
  }

  componentDidCatch(error: Error) {
    console.error('Query boundary caught an error:', error);
  }

  render() {
    if (this.state.hasError) {
      return (
        this.props.fallback || (
          <ErrorCard
            error={{
              message: 'An unexpected error occurred while fetching data.',
            }}
            className="mx-auto max-w-md"
          />
        )
      );
    }

    return this.props.children;
  }
}

// Example usage with optimistic updates
interface OptimisticUpdateConfig<TData> {
  queryKey: string[];
  mutationFn: (variables: any) => Promise<TData>;
  optimisticData: (variables: any) => TData;
  onError?: (error: Error) => void;
  onSuccess?: (data: TData) => void;
}

export function useOptimisticUpdate<TData>({
  queryKey,
  mutationFn,
  optimisticData,
  onError,
  onSuccess,
}: OptimisticUpdateConfig<TData>) {
  const queryClient = useQueryClient();

  return useMutation({
    mutationFn,
    onMutate: async (variables) => {
      await queryClient.cancelQueries({ queryKey });

      const previousData = queryClient.getQueryData(queryKey);

      queryClient.setQueryData(queryKey, optimisticData(variables));

      return { previousData };
    },
    onError: (err, _, context) => {
      if (context?.previousData) {
        queryClient.setQueryData(queryKey, context.previousData);
      }
      if (err instanceof Error && onError) {
        onError(err);
      }
    },
    onSuccess: (data) => {
      if (onSuccess) {
        onSuccess(data);
      }
    },
    onSettled: () => {
      queryClient.invalidateQueries({ queryKey });
    },
  });
}
```
