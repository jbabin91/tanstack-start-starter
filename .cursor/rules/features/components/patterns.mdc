# Component Patterns

## Component Types

1. **UI Components**

   - Buttons, Inputs, Cards
   - Layout components
   - Navigation elements
   - Feedback components

2. **Feature Components**

   - Business logic
   - Data fetching
   - State management
   - User interactions

3. **Layout Components**

   - Page layouts
   - Grid systems
   - Container components
   - Responsive layouts

4. **Composite Components**

   - Forms
   - Data tables
   - Complex UIs
   - Multi-step flows

## Component Structure

### Base Component

```typescript
// components/[ComponentName]/types.ts
export type ComponentProps = React.HTMLAttributes<HTMLDivElement> & {
  className?: string;
  children?: React.ReactNode;
  variant?: 'default' | 'primary' | 'secondary';
  size?: 'sm' | 'md' | 'lg';
};

// components/[ComponentName]/use-component-logic.ts
import { useState, useCallback, useId } from 'react';
import type { ComponentProps } from './types';

export function useComponentLogic(props: ComponentProps) {
  const [state, setState] = useState<string>('');

  const handleAction = useCallback(() => {
    setState((prev) => prev + '1');
  }, []);

  return {
    state,
    handlers: {
      handleAction,
    },
  } as const;
}

// components/[ComponentName]/ComponentName.tsx
import type { ComponentProps } from './types';
import { useComponentLogic } from './use-component-logic';
import { cn } from '~/lib/utils';

export function ComponentName({
  className,
  children,
  variant = 'default',
  size = 'md',
  ...props
}: ComponentProps) {
  const { state, handlers } = useComponentLogic(props);

  return (
    <div
      className={cn(
        'base-styles',
        {
          'variant-default': variant === 'default',
          'variant-primary': variant === 'primary',
          'variant-secondary': variant === 'secondary',
          'size-sm': size === 'sm',
          'size-md': size === 'md',
          'size-lg': size === 'lg',
        },
        className
      )}
      {...props}
    >
      {children}
    </div>
  );
}

// components/[ComponentName]/index.ts
export { ComponentName } from './ComponentName';
export type { ComponentProps } from './types';
```

### Feature Component

```typescript
import { useCallback } from 'react';
import { useQuery, useMutation } from '@tanstack/react-query';
import type { ApiError } from '~/lib/errors/types';
import type { User, UpdateUserData } from './types';
import { Card } from '~/components/ui/card';
import { UserProfileSkeleton } from './UserProfileSkeleton';
import { ErrorCard } from '~/components/ui/error-card';
import { EmptyState } from '~/components/ui/empty-state';
import { UserInfo } from './UserInfo';

type UserProfileProps = {
  userId: string;
};

export function UserProfile({ userId }: UserProfileProps) {
  // Data fetching
  const {
    data: user,
    isLoading,
    error,
  } = useQuery<User, ApiError>({
    queryKey: ['user', userId],
    queryFn: () => fetchUser(userId),
  });

  // Mutation
  const { mutate: updateUser } = useMutation<User, ApiError, UpdateUserData>({
    mutationFn: (data) => updateUserProfile(data),
    onSuccess: () => {
      // Handle success
    },
    onError: (error) => {
      // Handle error
    },
  });

  // Event handlers
  const handleUpdate = useCallback(
    async (data: UpdateUserData) => {
      updateUser(data);
    },
    [updateUser]
  );

  // Loading state
  if (isLoading) {
    return <UserProfileSkeleton />;
  }

  // Error state
  if (error) {
    return (
      <ErrorCard
        error={error}
        onRetry={() => refetch()}
      />
    );
  }

  // Empty state
  if (!user) {
    return (
      <EmptyState
        icon={UserIcon}
        title="User Not Found"
        description="The requested user could not be found."
        action={<Button onClick={() => navigate(-1)}>Go Back</Button>}
      />
    );
  }

  // Success state
  return (
    <Card>
      <UserInfo user={user} onUpdate={handleUpdate} />
    </Card>
  );
}
```

### Data Display

```typescript
import {
  type ColumnDef,
  flexRender,
  getCoreRowModel,
  useReactTable,
} from '@tanstack/react-table';
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from '~/components/ui/table';
import { DataTablePagination } from './DataTablePagination';
import type { TableMeta } from './types';

type DataTableProps<TData> = {
  data: TData[];
  columns: ColumnDef<TData>[];
  pagination?: {
    pageSize: number;
    pageIndex: number;
    total: number;
    onPageChange: (page: number) => void;
  };
  meta?: TableMeta;
};

export function DataTable<TData>({
  data,
  columns,
  pagination,
  meta,
}: DataTableProps<TData>) {
  const table = useReactTable({
    data,
    columns,
    getCoreRowModel: getCoreRowModel(),
    meta,
    manualPagination: true,
    pageCount: pagination ? Math.ceil(pagination.total / pagination.pageSize) : undefined,
  });

  return (
    <div className="relative space-y-4">
      <div className="rounded-md border">
        <Table>
          <TableHeader>
            {table.getHeaderGroups().map((headerGroup) => (
              <TableRow key={headerGroup.id}>
                {headerGroup.headers.map((header) => (
                  <TableHead key={header.id}>
                    {flexRender(
                      header.column.columnDef.header,
                      header.getContext()
                    )}
                  </TableHead>
                ))}
              </TableRow>
            ))}
          </TableHeader>
          <TableBody>
            {table.getRowModel().rows.map((row) => (
              <TableRow key={row.id}>
                {row.getVisibleCells().map((cell) => (
                  <TableCell key={cell.id}>
                    {flexRender(
                      cell.column.columnDef.cell,
                      cell.getContext()
                    )}
                  </TableCell>
                ))}
              </TableRow>
            ))}
          </TableBody>
        </Table>
      </div>
      {pagination && (
        <DataTablePagination
          pageSize={pagination.pageSize}
          pageIndex={pagination.pageIndex}
          total={pagination.total}
          onPageChange={pagination.onPageChange}
        />
      )}
    </div>
  );
}
```

