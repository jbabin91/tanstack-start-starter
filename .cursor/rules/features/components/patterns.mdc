### Feedback Components

```typescript
import type { HTMLAttributes } from 'react';
import { cva, type VariantProps } from 'class-variance-authority';
import { cn } from '~/lib/utils';

const spinnerVariants = cva(
  'animate-spin rounded-full border-2 border-current border-t-transparent',
  {
    variants: {
      size: {
        sm: 'h-4 w-4',
        md: 'h-6 w-6',
        lg: 'h-8 w-8',
      },
    },
    defaultVariants: {
      size: 'md',
    },
  }
);

type LoadingSpinnerProps = React.HTMLAttributes<HTMLDivElement> &
  VariantProps<typeof spinnerVariants> & {
    label?: string;
  };

export function LoadingSpinner({
  size,
  className,
  label = 'Loading',
  ...props
}: LoadingSpinnerProps) {
  return (
    <div
      className={cn(spinnerVariants({ size }), className)}
      role="status"
      aria-label={label}
      {...props}
    >
      <span className="sr-only">{label}</span>
    </div>
  );
}

type EmptyStateProps = {
  icon: React.ComponentType<{ className?: string }>;
  title: string;
  description: string;
  action?: React.ReactNode;
  className?: string;
  role?: 'alert' | 'status';
};

export function EmptyState({
  icon: Icon,
  title,
  description,
  action,
  className,
  role = 'status',
}: EmptyStateProps) {
  return (
    <div
      className={cn('flex flex-col items-center p-8 text-center', className)}
      role={role}
    >
      <Icon
        className="h-12 w-12 text-muted-foreground"
        aria-hidden="true"
      />
      <h3 className="mt-4 font-medium">{title}</h3>
      <p className="text-sm text-muted-foreground">{description}</p>
      {action && (
        <div className="mt-4" role="group" aria-label="Empty state actions">
          {action}
        </div>
      )}
    </div>
  );
}

type ErrorCardProps = {
  error: {
    message: string;
    code?: string;
  };
  onRetry?: () => void;
  className?: string;
};

export function ErrorCard({
  error,
  onRetry,
  className,
}: ErrorCardProps) {
  return (
    <div
      className={cn(
        'rounded-lg border border-destructive bg-destructive/10 p-4',
        className
      )}
      role="alert"
    >
      <div className="flex items-start gap-4">
        <XCircleIcon className="h-5 w-5 text-destructive" aria-hidden="true" />
        <div className="flex-1">
          <h3 className="font-medium text-destructive">Error</h3>
          <p className="text-sm text-destructive/90">{error.message}</p>
          {error.code && (
            <p className="mt-1 text-xs text-destructive/80">
              Code: {error.code}
            </p>
          )}
          {onRetry && (
            <button
              onClick={onRetry}
              className="mt-2 text-sm font-medium text-destructive hover:text-destructive/90"
            >
              Try again
            </button>
          )}
        </div>
      </div>
    </div>
  );
}
```

### Form Components

```typescript
import { useForm } from '@tanstack/react-form';
import { z } from 'zod';
import { cn } from '~/lib/utils';

type FormFieldProps = React.HTMLAttributes<HTMLDivElement> & {
  label: string;
  error?: string;
  description?: string;
  required?: boolean;
};

export function FormField({
  label,
  error,
  description,
  required,
  className,
  children,
  ...props
}: FormFieldProps) {
  const id = useId();

  return (
    <div className={cn('space-y-2', className)} {...props}>
      <div className="flex items-center justify-between">
        <label
          htmlFor={id}
          className={cn(
            'text-sm font-medium leading-none',
            error && 'text-destructive'
          )}
        >
          {label}
          {required && <span className="text-destructive">*</span>}
        </label>
        {error && (
          <p className="text-xs text-destructive" role="alert">
            {error}
          </p>
        )}
      </div>
      {description && (
        <p className="text-xs text-muted-foreground">{description}</p>
      )}
      {children}
    </div>
  );
}

type FormProps<TSchema extends z.ZodType> = {
  schema: TSchema;
  onSubmit: (values: z.infer<TSchema>) => Promise<void> | void;
  defaultValues?: Partial<z.infer<TSchema>>;
  children: React.ReactNode;
  className?: string;
};

export function Form<TSchema extends z.ZodType>({
  schema,
  onSubmit,
  defaultValues,
  children,
  className,
}: FormProps<TSchema>) {
  const form = useForm({
    defaultValues,
    onSubmit: async (values) => {
      try {
        await onSubmit(values);
      } catch (error) {
        if (error instanceof Error) {
          form.setFieldError('root', error.message);
        }
      }
    },
    validate: (values) => {
      const result = schema.safeParse(values);
      if (!result.success) {
        return Object.fromEntries(
          result.error.errors.map((error) => [
            error.path.join('.'),
            error.message,
          ])
        );
      }
      return {};
    },
  });

  return (
    <form
      onSubmit={form.handleSubmit}
      className={cn('space-y-4', className)}
      noValidate
    >
      {form.getFieldError('root') && (
        <div
          className="rounded-md bg-destructive/10 p-3 text-sm text-destructive"
          role="alert"
        >
          {form.getFieldError('root')}
        </div>
      )}
      {children}
    </form>
  );
}

// Example usage with validation schema
const loginSchema = z.object({
  email: z
    .string()
    .min(1, 'Email is required')
    .email('Invalid email address'),
  password: z
    .string()
    .min(1, 'Password is required')
    .min(8, 'Password must be at least 8 characters'),
  rememberMe: z.boolean().optional(),
});

export function LoginForm() {
  const [isLoading, setIsLoading] = useState<boolean>(false);
  const id = useId();

  const handleSubmit = useCallback(async (values: z.infer<typeof loginSchema>) => {
    setIsLoading(true);
    try {
      // Handle login logic
    } catch (error) {
      throw error;
    } finally {
      setIsLoading(false);
    }
  }, []);

  return (
    <Form
      schema={loginSchema}
      onSubmit={handleSubmit}
      className="max-w-sm space-y-6"
    >
      <FormField label="Email" required>
        {(field) => (
          <input
            type="email"
            className={cn(
              'w-full rounded-md border px-3 py-2',
              field.error && 'border-destructive'
            )}
            {...field.props}
          />
        )}
      </FormField>
      <FormField label="Password" required>
        {(field) => (
          <input
            type="password"
            className={cn(
              'w-full rounded-md border px-3 py-2',
              field.error && 'border-destructive'
            )}
            {...field.props}
          />
        )}
      </FormField>
      <FormField>
        {(field) => (
          <label className="flex items-center space-x-2">
            <input
              type="checkbox"
              className="rounded border-gray-300"
              {...field.props}
            />
            <span className="text-sm">Remember me</span>
          </label>
        )}
      </FormField>
      <button
        type="submit"
        className="w-full rounded-md bg-primary px-4 py-2 text-primary-foreground"
        disabled={isLoading}
      >
        {isLoading ? <LoadingSpinner size="sm" /> : 'Sign in'}
      </button>
    </Form>
  );
}
```

## Component Best Practices

1. **Component Design**

   - Single responsibility
   - Composable interfaces
   - Proper prop types
   - Consistent styling
   - Accessibility first

2. **State Management**

   - Controlled vs uncontrolled
   - Prop drilling vs context
   - Server state vs client state
   - Form state handling
   - Loading states

3. **Performance**

   - Proper memoization
   - Lazy loading
   - Code splitting
   - Bundle optimization
   - Render optimization

4. **Error Handling**

   - Error boundaries
   - Loading states
   - Empty states
   - Error messages
   - Recovery actions

5. **Accessibility**
   - ARIA attributes
   - Keyboard navigation
   - Screen reader support
   - Color contrast
   - Focus management

## Types

```typescript
// Type utilities
type Nullable<T> = T | null;
type Optional<T> = T | undefined;
type RequireAtLeastOne<T> = {
  [K in keyof T]-?: Required<Pick<T, K>> &
    Partial<Pick<T, Exclude<keyof T, K>>>;
}[keyof T];
type RequireOnlyOne<T> = {
  [K in keyof T]-?: Required<Pick<T, K>> &
    Partial<Record<Exclude<keyof T, K>, never>>;
}[keyof T];

// Component base types
type ComponentWithChildren<P = {}> = P & {
  children?: React.ReactNode;
};

type ComponentWithClassName<P = {}> = P & {
  className?: string;
};

type BaseComponentProps<P = {}> = ComponentWithChildren<
  ComponentWithClassName<P>
>;

// Common prop types
type Size = 'sm' | 'md' | 'lg';
type Variant = 'default' | 'primary' | 'secondary';
type Status = 'idle' | 'loading' | 'success' | 'error';

type WithSize<P = {}> = P & {
  size?: Size;
};

type WithVariant<P = {}> = P & {
  variant?: Variant;
};

type WithStatus<P = {}> = P & {
  status?: Status;
};

// Updated component types
type ComponentProps = BaseComponentProps<
  WithSize<
    WithVariant<{
      // Additional props here
    }>
  >
> &
  React.HTMLAttributes<HTMLDivElement>;

type LoadingSpinnerProps = BaseComponentProps<
  WithSize<{
    label?: string;
  }>
> &
  React.HTMLAttributes<HTMLDivElement>;

type EmptyStateProps = BaseComponentProps<{
  icon: React.ComponentType<{ className?: string }>;
  title: string;
  description: string;
  action?: React.ReactNode;
  role?: 'alert' | 'status';
}>;

type ErrorCardProps = BaseComponentProps<{
  error: {
    message: string;
    code?: string;
  };
  onRetry?: () => void;
}>;

// Form types
type FieldValue = string | number | boolean | null;
type FieldError = string | null;

type FormFieldProps<T extends FieldValue = string> = BaseComponentProps<{
  label: string;
  value: T;
  onChange: (value: T) => void;
  error?: FieldError;
  description?: string;
  required?: boolean;
  disabled?: boolean;
}>;

type FormProps<TSchema extends z.ZodType> = BaseComponentProps<{
  schema: TSchema;
  onSubmit: (values: z.infer<TSchema>) => Promise<void> | void;
  defaultValues?: Partial<z.infer<TSchema>>;
}>;

// Data types
type SortDirection = 'asc' | 'desc';
type SortConfig = {
  column: string;
  direction: SortDirection;
};

type PaginationConfig = {
  pageSize: number;
  pageIndex: number;
  total: number;
};

type DataTableProps<TData extends Record<string, unknown>> =
  BaseComponentProps<{
    data: TData[];
    columns: ColumnDef<TData>[];
    pagination?: PaginationConfig;
    sorting?: SortConfig;
    onPaginationChange?: (config: PaginationConfig) => void;
    onSortingChange?: (config: SortConfig) => void;
    meta?: TableMeta;
  }>;
```

