{
  "name": "tanstack-start-starter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vinxi build",
    "db:generate": "drizzle-kit generate --config ./drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config ./drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config ./drizzle.config.ts",
    "dev": "vinxi dev",
    "format": "prettier -uwl --cache .",
    "format:check": "prettier -uc --cache .",
    "lint": "eslint --flag unstable_ts_config . --max-warnings 0 --cache --cache-location node_modules/.cache/.eslintcache",
    "lint:fix": "eslint --flag unstable_ts_config . --fix --cache --cache-location node_modules/.cache/.eslintcache",
    "prepare": "husky",
    "start": "dotenv ./node_modules/.bin/vinxi start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@mantine/hooks": "^7.14.0",
    "@paralleldrive/cuid2": "^2.2.2",
