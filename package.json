{
  "name": "tanstack-start-starter",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "auth": "pnpm dlx @better-auth/cli@latest",
    "auth:generate": "pnpm with-env pnpm auth generate --y --config ./app/lib/server/auth.ts --output ./app/lib/server/schema/auth.schema.ts && pnpm format",
    "build": "pnpm with-env vinxi build",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "pnpm with-env drizzle-kit migrate --config drizzle.config.ts",
    "db:studio": "pnpm with-env drizzle-kit studio --config drizzle.config.ts",
    "db:up": "docker compose up -d",
    "dev": "vinxi dev",
    "format": "prettier -uwl --cache .",
    "format:check": "prettier -uc --cache .",
    "lint": "eslint . --max-warnings 0 --cache --cache-location node_modules/.cache/eslint/.eslintcache",
    "lint:fix": "eslint . --fix --cache --cache-location node_modules/.cache/eslint/.eslintcache",
    "prepare": "husky",
    "start": "pnpm with-env vinxi start",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenvx run --"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-alert-dialog": "^1.1.7",
    "@radix-ui/react-aspect-ratio": "^1.1.3",
    "@radix-ui/react-avatar": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-collapsible": "^1.1.4",
    "@radix-ui/react-context-menu": "^2.2.7",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-hover-card": "^1.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-menubar": "^1.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.6",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-radio-group": "^1.2.4",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slider": "^1.2.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toggle": "^1.1.3",
    "@radix-ui/react-toggle-group": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@react-email/components": "^0.0.36",
    "@react-email/render": "1.0.6",
    "@t3-oss/env-core": "^0.12.0",
    "@tanstack/react-query": "^5.72.2",
    "@tanstack/react-query-devtools": "^5.72.2",
    "@tanstack/react-router": "^1.115.3",
    "@tanstack/react-router-with-query": "^1.115.3",
    "@tanstack/react-start": "^1.115.3",
    "@tanstack/router-devtools": "^1.115.3",
    "@tanstack/zod-adapter": "^1.115.3",
    "better-auth": "^1.2.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.41.0",
    "drizzle-zod": "^0.7.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "js-cookie": "^3.0.5",
    "nanoid": "^5.1.5",
    "next-themes": "^0.4.6",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "react": "^19.1.0",
    "react-day-picker": "8.10.1",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.55.0",
    "react-icons": "^5.5.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.15.2",
    "resend": "^4.2.0",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.2.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "vinxi": "0.5.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.8.0",
    "@dotenvx/dotenvx": "^1.39.1",
    "@eslint-react/eslint-plugin": "^1.45.1",
    "@eslint/js": "^9.24.0",
    "@tailwindcss/postcss": "^4.1.3",
    "@tailwindcss/vite": "^4.1.3",
    "@tanstack/eslint-plugin-query": "^5.72.2",
    "@tanstack/eslint-plugin-router": "^1.115.0",
    "@types/eslint": "^9.6.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint-plugin-jsx-a11y": "^6.10.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-compiler": "19.0.0-beta-e993439-20250405",
    "commitlint": "^19.8.0",
    "cz-git": "^1.11.1",
    "drizzle-kit": "^0.30.6",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-import-x": "^4.10.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "19.0.0-beta-e993439-20250405",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-keys-fix": "^1.1.2",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "eslint-plugin-unicorn": "^58.0.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-packagejson": "^2.5.10",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "react-scan": "^0.3.3",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.1",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "node": ">=22.14.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ]
  }
}
