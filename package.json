    "postgres": "^3.4.5",
    "react": "19.0.0-rc.1",
    "react-day-picker": "9.3.0",
    "react-dom": "19.0.0-rc.1",
    "react-hook-form": "^7.53.2",
    "react-icons": "^5.3.0",
    "react-phone-number-input": "^3.4.9",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.5.4",
    "vaul": "^1.1.1",
    "vinxi": "^0.4.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.3",
    "@eslint/js": "^9.15.0",
    "@faker-js/faker": "^9.2.0",
